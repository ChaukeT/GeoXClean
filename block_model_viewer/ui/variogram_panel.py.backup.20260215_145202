                df_model.to_csv(model_path, index=False)

            # Export directional variogram data
            for direction in ['downhole', 'omni', 'major', 'minor', 'vertical']:
                if direction in self.variogram_results:
                    vario_data = self.variogram_results[direction]
                    if isinstance(vario_data, dict):
                        dist = vario_data.get('dist', [])
                        gamma = vario_data.get('gamma', [])
                        npairs = vario_data.get('npairs', [])

                        if len(dist) > 0:
                            df_vario = pd.DataFrame({
                                'Distance': dist,
                                'Gamma': gamma,
                                'Pairs': npairs
                            })
                            vario_path = os.path.join(save_dir, f'variogram_{direction}.csv')
                            df_vario.to_csv(vario_path, index=False)

            QMessageBox.information(
                self,
                "Export Complete",
                f"Variogram results exported successfully to:\n{save_dir}"
            )

        except Exception as e:
            logger.error(f"Failed to export variogram results: {e}", exc_info=True)
            QMessageBox.critical(
                self,
                "Export Failed",
                f"Failed to export variogram results:\n{str(e)}"
            )

    def clear_results(self):
        """Clear variogram results and reset state."""
        self.variogram_results = None
        # Force reset running flag if stuck
        self._is_running = False
        if hasattr(self, 'info_text') and self.info_text is not None and not self._is_qt_object_deleted(self.info_text):
            self.info_text.clear()
        # Safely clear toolbar before clearing figures to avoid QAction deletion issues
        self._safe_clear_toolbar()
        for c in [self.canvas_downhole, self.canvas_omni, self.canvas_3d]:
            if c is not None and not self._is_qt_object_deleted(c):
                c.clear_figure()
        # Re-enable run button
        if hasattr(self, "run_btn"):
            self.run_btn.setEnabled(True)
            self.run_btn.setText("Run Analysis")

    def clear_panel(self):
        """Clear all panel UI and state to initial defaults."""
        # Clear internal state
        self.drillhole_data = None

        # Clear results (reuse existing method)
        self.clear_results()

        # Call base class to clear common widgets
        super().clear_panel()
        logger.info("VariogramAnalysisPanel: Panel fully cleared")

    def _on_variable_changed(self):
        self.clear_results()

