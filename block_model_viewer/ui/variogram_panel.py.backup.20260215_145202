    def _on_tab_changed(self, idx):
        """Re-parent toolbar to current canvas when tab changes."""
        # Skip during analysis to avoid QAction deletion issues
        if getattr(self, "_is_running", False):
            return
        
        try:
            # Check if tabs widget is still valid
            if not hasattr(self, 'tabs') or self.tabs is None or self._is_qt_object_deleted(self.tabs):
                return
            
            current = self.tabs.widget(idx)
            if current is None or self._is_qt_object_deleted(current):
                return
            
            if isinstance(current, VariogramCanvas):
                self._safe_clear_toolbar()
                # Create new toolbar for current canvas
                # Use the toolbar_container as parent instead of self to avoid parent issues
                parent_widget = getattr(self, 'toolbar_container', None)
                if parent_widget is not None and not self._is_qt_object_deleted(parent_widget):
                    if hasattr(parent_widget, 'isVisible') and parent_widget.isVisible():
                        self.toolbar = NavigationToolbar(current, parent_widget)
                        if hasattr(self, 'toolbar_layout') and self.toolbar_layout is not None:
                            self.toolbar_layout.addWidget(self.toolbar)
                    else:
                        logger.debug("Skipping toolbar creation - parent widget not visible")
                else:
                    logger.debug("Skipping toolbar creation - parent widget not valid")
                
                # CRITICAL FIX: Force canvas redraw when tab becomes visible
                # This fixes the blank canvas issue on tab switch
                try:
                    current.draw_idle()
                    current.flush_events()
                    # Also force a Qt repaint to ensure visibility
                    current.update()
                    current.repaint()
                    logger.debug(f"Forced canvas redraw on tab switch to index {idx}")
                except Exception as draw_err:
                    logger.debug(f"Canvas redraw on tab switch failed: {draw_err}")
        except (RuntimeError, Exception) as e:
            logger.debug(f"Tab change toolbar update skipped: {e}")

    def _is_qt_object_deleted(self, obj) -> bool:
        """Check if a Qt/C++ object has been deleted.
        
        PyQt6 uses PyQt6.sip module for this check.
        Returns True if object is deleted or check fails (safer to assume deleted).
        """
        if obj is None:
            return True
        try:
            from PyQt6 import sip
            return sip.isdeleted(obj)
        except (ImportError, AttributeError):
            pass
        
        # Fallback: try accessing a simple property
        try:
            _ = obj.objectName()
            return False
        except (RuntimeError, AttributeError):
            return True
    
    def _safe_clear_toolbar(self):
        """Disconnect and delete the dynamic toolbar safely.
        
        IMPORTANT: We intentionally do NOT iterate over toolbar.actions() because
        Qt may have already deleted the QAction C++ objects while Python still holds
        references. Simply iterating over deleted QAction pointers causes:
        'RuntimeError: wrapped C/C++ object of type QAction has been deleted'
        
        We MUST disconnect the toolbar from its canvas before deleting, otherwise
        the canvas will try to fire events to the deleted toolbar during draw().
        """
        toolbar = getattr(self, "toolbar", None)
        if toolbar is None:
            return
        
        # Clear the reference FIRST to prevent any re-entry issues
        self.toolbar = None

        # Check if the C++ object is still valid
        if self._is_qt_object_deleted(toolbar):
            return

        # CRITICAL: Disconnect toolbar from canvas to prevent deleted QAction errors
        # NavigationToolbar2QT connects to canvas via mpl_connect for various events.
        # If we delete the toolbar without disconnecting, the canvas will fire events
        # to the deleted toolbar during draw(), causing "QAction has been deleted" errors.
        try:
            # Break circular reference by setting canvas to None
            # This is more reliable than trying to disconnect individual event handlers
            if hasattr(toolbar, 'canvas'):
                toolbar.canvas = None
        except (RuntimeError, AttributeError, Exception):
            pass

        # Remove from layout
        try:
            if hasattr(self, 'toolbar_layout') and self.toolbar_layout is not None:
                self.toolbar_layout.removeWidget(toolbar)
        except (RuntimeError, Exception):
            pass
        
        # Hide the toolbar to prevent any further interaction
        try:
            if not self._is_qt_object_deleted(toolbar):
                toolbar.hide()
        except (RuntimeError, Exception):
            pass
        
        # Set parent to None to break Qt parent-child relationship
        try:
            if not self._is_qt_object_deleted(toolbar):
                toolbar.setParent(None)
        except (RuntimeError, Exception):
            pass
        
        # Schedule for deletion - Qt will clean up all child QActions
        try:
            if not self._is_qt_object_deleted(toolbar):
                toolbar.deleteLater()
        except (RuntimeError, Exception):
            pass

    def closeEvent(self, event):
        """Ensure toolbars are cleaned up to avoid deleted QAction errors on reopen."""
        # Disconnect tab signal first
        try:
            if hasattr(self, 'tabs') and self.tabs is not None and not self._is_qt_object_deleted(self.tabs):
                self.tabs.currentChanged.disconnect(self._on_tab_changed)
        except (TypeError, RuntimeError, Exception):
            pass
        
        # Clean up toolbar
        try:
            self._safe_clear_toolbar()
        except Exception:
            pass
        
        # Clear main_window references
        if getattr(self, "main_window", None):
            try:
                self.main_window.variogram_dialog = None
                self.main_window.variogram_panel = None
            except Exception:
                pass
        
        # Clear registry connection
        try:
            if hasattr(self, 'registry') and self.registry is not None and not self._is_qt_object_deleted(self.registry):
                if hasattr(self.registry, 'drillholeDataLoaded'):
                    try:
                        self.registry.drillholeDataLoaded.disconnect(self._on_data_loaded)
                    except (TypeError, RuntimeError):
                        pass
        except Exception:
            pass
        
        super().closeEvent(event)

    def _open_assistant(self):
        """Open the Variogram Assistant as a standalone panel (not a child dialog)."""
        # Use panel manager to open as standalone panel
        if hasattr(self, '_panel_manager') and self._panel_manager:
            # Open through panel manager (standalone, dockable panel)
            self._panel_manager.show_panel("VariogramAssistantPanel")
            
            # Get the panel instance and set up data/signals
            panel_info = self._panel_manager.get_panel_info("VariogramAssistantPanel")
            if panel_info and panel_info.instance:
                assistant_panel = panel_info.instance
                # Set drillhole data
                if hasattr(assistant_panel, 'set_drillhole_data'):
                    assistant_panel.set_drillhole_data(self.drillhole_data)
                # Connect signal for model acceptance
                try:
                    assistant_panel.model_accepted.disconnect()
                except (TypeError, RuntimeError):
                    pass
                assistant_panel.model_accepted.connect(self._apply_assistant_model)
                logger.info("Opened Variogram Assistant as standalone panel")
        else:
            # Fallback: create as child dialog if panel manager not available
            from .variogram_assistant_panel import VariogramAssistantPanel
            # Check if assistant dialog already exists and is valid
            if hasattr(self, '_assistant_dialog') and self._assistant_dialog is not None:
                try:
                    if self._assistant_dialog.isVisible():
                        self._assistant_dialog.raise_()
                        self._assistant_dialog.activateWindow()
                        return
                except RuntimeError:
                    self._assistant_dialog = None
            
            dlg = VariogramAssistantPanel(self)
            self._assistant_dialog = dlg  # Store reference
            dlg.set_drillhole_data(self.drillhole_data)
            try:
                dlg.model_accepted.disconnect()
            except TypeError:
                pass
            dlg.model_accepted.connect(self._apply_assistant_model)
            dlg.show()
            logger.warning("Opened Variogram Assistant as child dialog (panel manager not available)")

