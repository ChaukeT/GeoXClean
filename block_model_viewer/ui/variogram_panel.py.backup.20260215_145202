    def _optimize_lags(self):
        """Auto-calculate lags based on data geometry."""
        if self.drillhole_data is None: return
        
        coords = self.drillhole_data[['X','Y','Z']].dropna().values
        if len(coords) < 5: return
        
        # 1. Horizontal Spacing (using Nearest Neighbors)
        from sklearn.neighbors import NearestNeighbors
        nn = NearestNeighbors(n_neighbors=2).fit(coords[:, :2])
        dists, _ = nn.kneighbors(coords[:, :2])
        h_spacing = float(np.percentile(dists[:, 1], 75)) # 75th percentile to avoid duplicates
        
        # 2. Vertical Spacing
        v_spacing = 2.0 # Default
        # Try to find FROM/TO
        if 'TO' in self.drillhole_data.columns and 'FROM' in self.drillhole_data.columns:
            lens = (self.drillhole_data['TO'] - self.drillhole_data['FROM']).median()
            if lens > 0: v_spacing = float(lens)
            
        # 3. Rules
        lag = max(5.0, h_spacing * 0.5)
        tol = lag * 0.5
        n_lags = 15
        
        self.lag_dist_spin.setValue(lag)
        self.lag_tol_spin.setValue(tol)
        self.nlag_spin.setValue(n_lags)
        
        self.info_text.setText(
            f"<b>Auto-Optimized Lags:</b><br>"
            f"Horizontal Spacing: {h_spacing:.1f} m<br>"
            f"Vertical Spacing: {v_spacing:.1f} m<br>"
            f"Recommended Lag: {lag:.1f} m"
        )

    def _check_data_lineage(self) -> bool:
        """
        HARD GATE: Verify data lineage before variogram analysis.

        Checks:
        1. QC-Validated (MUST pass or warn - HARD STOP on FAIL/NOT_RUN)
        2. Prefers declustered data if available
        3. Warns if using raw assays instead of composites
        4. Logs lineage information for audit trail

        Returns:
            True if data is acceptable for variogram analysis
        """
        registry = getattr(self, 'registry', None)
        if not registry:
            logger.warning("LINEAGE: No registry available - cannot verify data lineage")
            return True  # Allow to proceed but log warning

        # HARD GATE: Use require_validation_for_estimation() method
        # This enforces JORC/SAMREC compliance - NO estimation without validation
        allowed, message = registry.require_validation_for_estimation()
        if not allowed:
            logger.error(f"LINEAGE HARD GATE: {message}")
            QMessageBox.critical(
                self, "Validation Required",
                f"Cannot run variogram analysis:\n\n{message}\n\n"
                "Open the QC Window to validate your data before running geostatistical analysis."
            )
            return False

        # Log validation status for audit trail
        validation_state = registry.get_drillholes_validation_state()
        if validation_state:
            status = validation_state.get("status", "UNKNOWN")
            if status == "WARN":
                logger.warning(
                    "LINEAGE: Validation passed with warnings. "
                    "Review warnings for JORC/SAMREC compliance."
                )
            else:
                logger.info(f"LINEAGE: Validation status = {status}")

        # Check if using declustered data
        if getattr(self, '_using_declustered', False):
            logger.info("LINEAGE: Using declustered data for variogram analysis (recommended)")
            return True

        # Check if composites are available
        dh_data = registry.get_drillhole_data(copy_data=False)
        if dh_data:
            has_composites = isinstance(dh_data.get('composites'), pd.DataFrame) and not dh_data.get('composites').empty
            has_assays = isinstance(dh_data.get('assays'), pd.DataFrame) and not dh_data.get('assays').empty

            if hasattr(self, 'data_source_raw') and self.data_source_raw.isChecked():
                if has_composites:
                    logger.warning(
                        "LINEAGE WARNING: Using raw assays for variogram analysis when composites are available. "
                        "This may produce variograms with inconsistent sample support. "
                        "Consider using composites or declustered data for JORC/SAMREC compliance."
                    )
                else:
                    logger.info("LINEAGE: Using raw assays (composites not available)")
            else:
                logger.info("LINEAGE: Using composited data for variogram analysis")

        return True

    def run_analysis(self):
        # Simple guard against concurrent runs
        if getattr(self, "_is_running", False):
            logger.warning("Analysis already running - skipping")
            return
        
        if self.drillhole_data is None:
            logger.warning("No drillhole data available")
            return
        
        var = self.var_combo.currentText()
        if not var:
            logger.warning("No variable selected")
            return
        
        # HARD GATE: Check data lineage before proceeding
        if not self._check_data_lineage():
            return
        
        logger.info(f"Starting variogram analysis for variable: {var}")
        
        # Check for declustered data first (preferred for variogram analysis)
        registry = getattr(self, 'registry', None)
        declust_data = None
        if registry:
            declust_results = registry.get_declustering_results()
            if declust_results and 'weighted_dataframe' in declust_results:
                declust_df = declust_results['weighted_dataframe']
                if var in declust_df.columns and 'declust_weight' in declust_df.columns:
                    declust_data = declust_df.dropna(subset=['X','Y','Z', var])
                    logger.info(f"Using declustered data with {len(declust_data)} samples for variogram analysis")

        # Use declustered data if available, otherwise fall back to raw data
        if declust_data is not None and len(declust_data) > 0:
            df = declust_data
            self._using_declustered = True
            if hasattr(self, 'data_source_status_label'):
                self.data_source_status_label.setText("Using: ✅ Declustered data")
                self.data_source_status_label.setStyleSheet("font-size: 9px; color: #4CAF50;")
        else:
            df = self.drillhole_data.dropna(subset=['X','Y','Z', var])
            self._using_declustered = False
            if hasattr(self, 'data_source_status_label'):
                # Update status based on current selection
                if hasattr(self, 'data_source_composited') and self.data_source_composited.isChecked():
                    self.data_source_status_label.setText("Using: Composited data")
                elif hasattr(self, 'data_source_raw') and self.data_source_raw.isChecked():
                    self.data_source_status_label.setText("Using: Raw assay data")
                else:
                    self.data_source_status_label.setText("Using: Raw drillhole data")
                self.data_source_status_label.setStyleSheet("font-size: 9px; color: #FF9800;")
            if registry and registry.get_declustering_results():
                logger.warning("Declustered data available but missing required columns - using raw data")
        
        self._is_running = True
        if hasattr(self, "run_btn"):
            self.run_btn.setEnabled(False)
            self.run_btn.setText("Running...")
        if hasattr(self, "progress_bar"):
            self.progress_bar.setVisible(True)
            self.progress_bar.setValue(0)
            self.progress_bar.setFormat("Variogram Analysis: Starting...")
        
        # Force initial UI update using safer processEvents
        from PyQt6.QtCore import QEventLoop
        from PyQt6.QtWidgets import QApplication
        QApplication.processEvents(QEventLoop.ProcessEventsFlag.ExcludeUserInputEvents)
        
        # Block tab change signal during analysis to prevent toolbar manipulation
        # This is critical to avoid "wrapped C/C++ object of type QAction has been deleted" errors
        tab_signal_blocked = False
        try:
            if hasattr(self, 'tabs') and self.tabs is not None and not self._is_qt_object_deleted(self.tabs):
                self.tabs.blockSignals(True)
                tab_signal_blocked = True
        except (RuntimeError, Exception):
            pass
        
        try:
            # Get professional features settings
            auto_lags = self.auto_lags_checkbox.isChecked()
            n_structures = self.struct_spin.value()
            global_nugget = None
            if self.global_nugget_checkbox.isChecked():
                global_nugget = self.global_nugget_spin.value()
            
            # Progress callback for updating the progress bar (throttled)
            _last_progress_pct = [0]  # Use list to allow modification in closure
            def update_progress(percent: int, message: str):
                if hasattr(self, "progress_bar") and self.progress_bar is not None:
                    # Only update every 5% to avoid UI signal flooding
                    if percent >= _last_progress_pct[0] + 5 or percent >= 100:
                        self.progress_bar.setValue(percent)
                        self.progress_bar.setFormat(f"Variogram Analysis: {message} ({percent}%)")
                        _last_progress_pct[0] = percent
                        # Force UI repaint using safer processEvents
                        from PyQt6.QtCore import QEventLoop
                        from PyQt6.QtWidgets import QApplication
                        QApplication.processEvents(QEventLoop.ProcessEventsFlag.ExcludeUserInputEvents)

            # Get manual azimuths if enabled
            default_azimuth = None
            default_dip = None
            if self.manual_azimuth_checkbox.isChecked():
                # Use major azimuth for primary direction, minor for secondary
                # For 3D variograms, we need to provide both major and minor azimuths
                # The pipeline will use these as overrides for the automatic detection
                default_azimuth = self.major_azimuth_spin.value()
                default_dip = 0.0  # Horizontal plane for now, could add dip controls later

            results = vg3d.run_variogram_pipeline(
                df,
                vcol=var,
                nlag=self.nlag_spin.value(),
                lag_distance=self.lag_dist_spin.value(),
                lag_tolerance=self.lag_tol_spin.value(),
                model_types=[self.model_combo.currentText().lower()],
                z_positive_up=True,
                # Manual azimuth override
                default_azimuth=default_azimuth,
                default_dip=default_dip,
                # New professional features
                auto_lags=auto_lags,
                n_structures=n_structures,
                global_nugget=global_nugget,
                progress_callback=update_progress,
                # DETERMINISM: Use UI-specified seed for reproducibility (JORC/SAMREC requirement)
                random_state=self.random_seed_spin.value()
            )
            
            self.variogram_results = results
            
            # =================================================================
            # AUDIT METADATA: Store all settings for reproducibility
            # =================================================================
            audit_metadata = {
                'random_seed': self.random_seed_spin.value(),
                'model_intent': self.model_intent_combo.currentText(),
                'range_cap_enabled': self.range_cap_checkbox.isChecked(),
                'range_cap_value': self.range_cap_spin.value() if self.range_cap_checkbox.isChecked() else None,
                'global_nugget_enabled': self.global_nugget_checkbox.isChecked(),
                'global_nugget_value': self.global_nugget_spin.value() if self.global_nugget_checkbox.isChecked() else None,
                'manual_azimuth_enabled': self.manual_azimuth_checkbox.isChecked(),
                'major_azimuth': self.major_azimuth_spin.value() if self.manual_azimuth_checkbox.isChecked() else None,
                'minor_azimuth': self.minor_azimuth_spin.value() if self.manual_azimuth_checkbox.isChecked() else None,
            }
            self.variogram_results['audit_metadata'] = audit_metadata

            # Update progress to 100%
            if hasattr(self, "progress_bar"):
                self.progress_bar.setValue(100)
                self.progress_bar.setFormat("Variogram Analysis: Complete")

            combined = self._build_combined_model()
            self.variogram_results['combined_3d_model'] = combined
            
            if self.registry:
                reg_payload = results.copy()
                reg_payload['variable'] = var
                
                # AUDIT REQUIREMENT: Add data lineage hash for JORC/SAMREC compliance
                try:
                    source_data_hash = compute_data_hash(df, var)
                    reg_payload['source_data_hash'] = source_data_hash
                    reg_payload['data_source_type'] = 'declustered' if self._using_declustered else 'raw'
                    logger.info(f"Variogram data lineage: hash={source_data_hash[:16]}..., source={reg_payload['data_source_type']}")
                except Exception as e:
                    logger.warning(f"Could not compute data lineage hash: {e}")
                
                # AUDIT REQUIREMENT: Analyze and log nugget consistency
                try:
                    # AUDIT FIX: Call analyze_nugget_consistency with correct signature
                    nugget_report = analyze_nugget_consistency(results)
                    if not nugget_report.is_consistent:
                        logger.warning(
                            f"Nugget consistency warning: ratio={nugget_report.ratio:.2f}, "
                            f"range=[{nugget_report.min_nugget:.3f}, {nugget_report.max_nugget:.3f}], "
                            f"recommended global={nugget_report.recommended_global:.3f}"
                        )
                        if nugget_report.warning_message:
                            logger.warning(f"  {nugget_report.warning_message}")
                    # Store as dict for JSON serialization
                    reg_payload['nugget_analysis'] = {
                        'is_consistent': nugget_report.is_consistent,
                        'min_nugget': nugget_report.min_nugget,
                        'max_nugget': nugget_report.max_nugget,
                        'median_nugget': nugget_report.median_nugget,
                        'ratio': nugget_report.ratio,
                        'recommended_global': nugget_report.recommended_global,
                        'warning_message': nugget_report.warning_message,
                    }
                except Exception as e:
                    logger.warning(f"Nugget consistency analysis failed: {e}")

                # AUDIT: Add explicit warnings summary for reports/exports
                metadata = results.get('metadata', {})
                warnings_summary = []

                # Subsampling warning
                if metadata.get('subsampled', False):
                    subsample_frac = metadata.get('subsample_fraction', 0)
                    warnings_summary.append(
                        f"DATA SUBSAMPLED: Used {subsample_frac*100:.0f}% of data "
                        f"(seed={metadata.get('subsample_seed', 'N/A')})"
                    )

                # Weak directions warning
                weak_dirs = metadata.get('weak_directions', [])
                for wd in weak_dirs:
                    if not isinstance(wd, dict):
                        continue  # Skip invalid entries
                    if wd.get('is_critical', False):
                        warnings_summary.append(
                            f"WEAK DIRECTION: {wd['direction']} has {wd['avg_pairs_per_lag']:.0f} "
                            f"pairs/lag (min=30 required)"
                        )

                if warnings_summary:
                    reg_payload['warnings'] = warnings_summary
                    reg_payload['has_warnings'] = True
                    logger.info(f"Variogram warnings for export: {warnings_summary}")
                else:
                    reg_payload['has_warnings'] = False

                self.registry.register_variogram_results(reg_payload, source_panel="Variogram")
            
            # Defer plot updates to avoid QAction deletion issues during analysis cleanup
            QTimer.singleShot(100, self._update_plots)
            QTimer.singleShot(200, self._update_info)
            logger.info("Variogram analysis completed successfully")
        except Exception as e:
            logger.error(f"Analysis failed: {e}", exc_info=True)
            QMessageBox.critical(self, "Error", f"Variogram analysis failed:\n{str(e)}")
        finally:
            # CRITICAL: Always reset _is_running flag, even if something goes wrong
            self._is_running = False
            logger.debug("Reset _is_running flag")
            
            # Unblock tab signals first
            if tab_signal_blocked:
                try:
                    if hasattr(self, 'tabs') and self.tabs is not None and not self._is_qt_object_deleted(self.tabs):
                        self.tabs.blockSignals(False)
                except (RuntimeError, Exception):
                    pass
            
            # NOTE: We intentionally do NOT rebuild the toolbar here.
            # Rebuilding the toolbar can cause "QAction has been deleted" errors
            # if the canvas still has stale event connections. The toolbar will
            # be updated naturally when the user changes tabs via _on_tab_changed.
            
            if hasattr(self, "run_btn"):
                self.run_btn.setEnabled(True)
                self.run_btn.setText("Run Analysis")  # Reset button text
            if hasattr(self, "progress_bar"):
                self.progress_bar.setVisible(False)
            
            # Force final UI update using safer processEvents
            from PyQt6.QtCore import QEventLoop
            from PyQt6.QtWidgets import QApplication
            QApplication.processEvents(QEventLoop.ProcessEventsFlag.ExcludeUserInputEvents)

    def _build_combined_model(self):
        """Construct the 3D Anisotropic model used for Kriging."""
        res = self.variogram_results
        fits = res.get('fitted_models', {})
        m_type = self.model_combo.currentText().lower()
        
        # Get fitted models for each direction
        major = fits.get('major', {}).get(m_type, {})
        minor = fits.get('minor', {}).get(m_type, {})
        downhole_fit = fits.get('downhole', {}).get(m_type, {})
        vertical_fit = fits.get('vertical', {}).get(m_type, {})
        omni_fit = fits.get('omni', {}).get(m_type, {})

        # Validate that at least one direction has fitted models
        if not any([major, minor, omni_fit, vertical_fit, downhole_fit]):
            logger.error("No fitted models available - cannot build combined model")
            raise ValueError(f"Variogram fitting failed for all directions (model type: {m_type})")

        # =================================================================
        # NUGGET: Check consistency across all directions first
        # =================================================================
        try:
            nugget_report = analyze_nugget_consistency(res)
            if not nugget_report.is_consistent:
                logger.warning(
                    f"Nugget inconsistency detected across directions: "
                    f"using recommended global nugget {nugget_report.recommended_global:.3f}"
                )
                nugget = nugget_report.recommended_global
                nugget_source = 'median_all_directions'
            else:
                # Consistent - use downhole (best for nugget due to tight spacing)
                if downhole_fit and 'nugget' in downhole_fit:
                    nugget = downhole_fit['nugget']
                    nugget_source = 'downhole'
                elif vertical_fit and 'nugget' in vertical_fit:
                    nugget = vertical_fit['nugget']
                    nugget_source = 'vertical'
                elif omni_fit and 'nugget' in omni_fit:
                    nugget = omni_fit['nugget']
                    nugget_source = 'omni'
                else:
                    nugget = 0
                    nugget_source = 'default'
                    logger.warning("No fitted model available for nugget - using 0")
        except Exception as e:
            # Fallback if nugget consistency check fails
            logger.warning(f"Nugget consistency check failed ({e}), using downhole")
            if downhole_fit:
                nugget = downhole_fit.get('nugget', 0)
                nugget_source = 'downhole_fallback'
            else:
                nugget = 0
                nugget_source = 'fallback_zero'
        
        # =================================================================
        # SILL: Use omni or major as reference (most pairs, most stable)
        # CRITICAL FIX: 'sill' key stores PARTIAL sill (C), not total sill!
        # total_sill = nugget + partial_sill (C0 + C)
        # =================================================================
        # Extract metadata from results
        metadata = res.get('metadata', {})
        # Get sample variance as ultimate fallback
        sample_var = metadata.get('sample_variance', 1.0)
        sill_source = 'unknown'

        # Get total sill from most reliable source (explicit checks to handle 0.0 values)
        if 'total_sill' in omni_fit and omni_fit['total_sill'] is not None and omni_fit['total_sill'] > 0:
            total_sill = omni_fit['total_sill']
            sill_source = 'omni'
        elif 'total_sill' in major and major['total_sill'] is not None and major['total_sill'] > 0:
            total_sill = major['total_sill']
            sill_source = 'major'
        else:
            # Fallback to sample variance
            total_sill = sample_var
            sill_source = 'sample_variance'
            logger.warning(f"No fitted total_sill available, using sample variance: {total_sill:.3f}")

        # Validate sill > nugget (with margin)
        if total_sill <= nugget * 1.05:
            logger.error(f"Total sill ({total_sill:.3f}) <= nugget ({nugget:.3f}). Correcting to maintain validity.")
            total_sill = max(nugget * 1.2, sample_var)
            sill_source = f'{sill_source}_corrected'

        # Partial sill (C) = total_sill - nugget
        partial_sill = max(total_sill - nugget, 0.01)

        # Validate nugget ratio (nugget should not dominate)
        nugget_ratio = nugget / (nugget + partial_sill) if (nugget + partial_sill) > 0 else 1.0
        if nugget_ratio > 0.9:
            logger.error(
                f"PURE NUGGET MODEL: nugget ratio = {nugget_ratio:.1%} (nugget={nugget:.3f}, partial_sill={partial_sill:.3f}). "
                f"Data shows minimal spatial structure! Check: 1) Data quality, 2) Duplicate samples, 3) Unit errors"
            )
        elif nugget_ratio > 0.7:
            logger.warning(f"High nugget ratio ({nugget_ratio:.1%}) - limited spatial structure for kriging")
        
        # =================================================================
        # INVARIANT ASSERTION: Fail fast if sill semantics are ever broken
        # total_sill MUST equal nugget + partial_sill (within numerical tolerance)
        # =================================================================
        # INVARIANT CHECK: total_sill MUST equal nugget + partial_sill
        # This is a mathematical identity - if violated, indicates a bug in parameter extraction
        if not np.isclose(total_sill, nugget + partial_sill, rtol=1e-5, atol=1e-9):
            error_msg = (
                f"CRITICAL: Sill invariant violated! "
                f"total_sill={total_sill:.6f}, nugget={nugget:.6f}, partial_sill={partial_sill:.6f}, "
                f"sum={nugget + partial_sill:.6f}. "
                f"This indicates a bug in model fitting or parameter extraction. "
                f"Sources: nugget from {nugget_source}, sill from {sill_source}"
            )
            logger.error(error_msg)

            # Import STRICT_MODE from gates
            try:
                from ..geostats.variogram_gates import STRICT_MODE
            except ImportError:
                STRICT_MODE = False

            # In strict mode, FAIL (don't auto-correct and hide the bug)
            if STRICT_MODE:
                raise ValueError(error_msg)

            # In non-strict mode, correct but log aggressively
            logger.critical("AUTO-CORRECTING sill invariant - this should NOT happen in production!")
            total_sill = nugget + partial_sill
        
        # =================================================================
        # RANGES: CRITICAL FIX - Use correct source for each direction!
        # - major_range: from major directional variogram (horizontal major)
        # - minor_range: from minor directional variogram (horizontal minor)
        # - vertical_range: from VERTICAL directional variogram (NOT downhole!)
        # Downhole is for NUGGET estimation only, not for anisotropy!
        # =================================================================
        major_range = major.get('range', 100)
        minor_range = minor.get('range', major_range * 0.5)  # Default to 50% of major
        
        # CRITICAL: vertical_range comes from VERTICAL fit, not downhole!
        # Downhole range is along-hole distance, not true vertical anisotropy.
        if vertical_fit and 'range' in vertical_fit and vertical_fit['range'] > 0:
            vertical_range = vertical_fit['range']
            vert_source = 'vertical'
        # Fallback: use downhole as proxy IF it's reliable
        elif downhole_fit and 'range' in downhole_fit and downhole_fit['range'] > 0:
            vertical_range = downhole_fit['range']
            vert_source = 'downhole_proxy'
            logger.warning(f"Using downhole range ({vertical_range:.1f}m) as vertical proxy - vertical variogram unavailable")
        # CRITICAL ERROR: Cannot build anisotropic model without vertical information
        else:
            error_msg = (
                "CRITICAL: No vertical or downhole range available. Cannot build anisotropic 3D model. "
                "Check: 1) dip_tolerance parameter, 2) vertical extent of drillhole data, 3) at least 2 holes"
            )
            logger.error(error_msg)
            raise ValueError(error_msg)
        
        # GEOSTATISTICAL FIX: Enforce proper range ordering (Major >= Minor >= Vertical)
        try:
            from ..geostats.anisotropy_utils import enforce_range_ordering, create_anisotropy_summary
            
            ordered_ranges, naming_info = enforce_range_ordering(
                major_range, minor_range, vertical_range, use_descriptive_names=False
            )

            # Validate returned structure
            required_keys = ["major_range", "minor_range", "vertical_range"]
            if not all(key in ordered_ranges for key in required_keys):
                logger.error(f"enforce_range_ordering returned invalid structure: {ordered_ranges.keys()}")
                raise ValueError("Anisotropy utility returned incomplete range data")

            # Use corrected ranges
            major_range = ordered_ranges["major_range"]
            minor_range = ordered_ranges["minor_range"]
            vertical_range = ordered_ranges["vertical_range"]
            
            # Store naming info for UI warnings
            aniso_warnings = naming_info.get("warnings", [])
            
        except ImportError:
            # CRITICAL FALLBACK: Enforce range ordering inline (MATHEMATICAL REQUIREMENT)
            logger.warning("Could not import anisotropy_utils - enforcing range ordering inline")
            ranges_sorted = sorted([major_range, minor_range, vertical_range], reverse=True)
            major_range, minor_range, vertical_range = ranges_sorted
            aniso_warnings = ["Range ordering enforced (fallback - anisotropy_utils not available)"]

        # VALIDATION: Ensure major >= minor >= vertical (with small tolerance for floating point)
        if not (major_range >= minor_range * 0.999):
            raise ValueError(f"CRITICAL: major_range ({major_range:.2f}) < minor_range ({minor_range:.2f}) after ordering!")
        if not (minor_range >= vertical_range * 0.999):
            raise ValueError(f"CRITICAL: minor_range ({minor_range:.2f}) < vertical_range ({vertical_range:.2f}) after ordering!")

        # RANGE REASONABLENESS VALIDATION
        lag_config = res.get('lag_config', {})
        max_range_computed = lag_config.get('max_range', 1000)  # from analysis
        min_lag = lag_config.get('lag_distance', 1)

        # Check if ranges are within reasonable bounds
        for range_name, range_val in [('major', major_range), ('minor', minor_range), ('vertical', vertical_range)]:
            if range_val < min_lag:
                logger.warning(f"{range_name} range ({range_val:.1f}m) < min lag distance ({min_lag:.1f}m) - may be numerical artifact")
            if range_val > max_range_computed * 2:
                logger.warning(f"{range_name} range ({range_val:.1f}m) > 2x analysis max_range ({max_range_computed:.1f}m) - extrapolating beyond data!")

        # =================================================================
        # GEOLOGICAL RANGE CAP (Professional practice for listed companies)
        # Auditors prefer "conservative but geological" over "optimal but implausible"
        # =================================================================
        range_cap_applied = False
        original_major_range = major_range
        if hasattr(self, 'range_cap_checkbox') and self.range_cap_checkbox.isChecked():
            range_cap = self.range_cap_spin.value()
            if major_range > range_cap:
                logger.info(f"GEOLOGICAL CAP: Major range {major_range:.1f}m capped to {range_cap:.1f}m")
                major_range = range_cap
                range_cap_applied = True
            if minor_range > range_cap:
                logger.info(f"GEOLOGICAL CAP: Minor range {minor_range:.1f}m capped to {range_cap:.1f}m")
                minor_range = range_cap
                range_cap_applied = True
            if vertical_range > range_cap:
                logger.info(f"GEOLOGICAL CAP: Vertical range {vertical_range:.1f}m capped to {range_cap:.1f}m")
                vertical_range = range_cap
                range_cap_applied = True
        
        logger.debug(f"Built 3D model: {m_type}, nugget={nugget:.3f} (from {nugget_source}), "
                    f"partial_sill={partial_sill:.3f}, total_sill={total_sill:.3f}, "
                    f"ranges=({major_range:.1f}, {minor_range:.1f}, {vertical_range:.1f}) (vert from {vert_source})"
                    f"{' [CAPPED]' if range_cap_applied else ''}")
        
        # =================================================================
        # SILL SEMANTICS (CRITICAL - industry standard):
        # 'sill' = partial sill (C) - the contribution above nugget
        # 'total_sill' = nugget + partial_sill (C0 + C) - total variance
        # =================================================================
        combined_model = {
            'model_type': m_type,
            'nugget': nugget,
            'sill': partial_sill,  # PARTIAL sill (C), NOT total!
            'total_sill': total_sill,  # Total sill (C0 + C)
            'major_range': major_range,
            'minor_range': minor_range,
            'vertical_range': vertical_range,
            'nugget_source': nugget_source,  # Track source for audit
            'vert_source': vert_source,  # Track source for audit
            'anisotropy_warnings': aniso_warnings,  # Range ordering warnings
            # AUDIT METADATA: Track geological constraints for defensibility
            'range_cap_applied': range_cap_applied,
            'range_cap_value': self.range_cap_spin.value() if range_cap_applied else None,
            'original_major_range': original_major_range if range_cap_applied else None,
            'model_intent': self.model_intent_combo.currentText() if hasattr(self, 'model_intent_combo') else 'Estimation (local accuracy)',
            'structures': [{
                'type': m_type,
                'contribution': partial_sill,  # Partial sill
                'major_range': major_range,
                'minor_range': minor_range,
                'vertical_range': vertical_range
            }]
        }
        
        return combined_model

    def _update_plots(self):
        """Update all variogram plots with error handling."""
        if not self.variogram_results:
            logger.warning("No variogram results to plot")
            return
        
        try:
            res = self.variogram_results
            fits = res.get('fitted_models', {})
            m_type = self.model_combo.currentText().lower()
            normalize = getattr(self, "normalize_y_checkbox", None)
            normalize_flag = normalize.isChecked() if normalize else False

            def plot(canvas, key, title, direction):
                """Plot with error handling to prevent QAction deletion errors from cascading."""
                plot_success = False
                try:
                    if self._is_qt_object_deleted(canvas):
                        logger.debug(f"Skipping plot for {key} - canvas deleted")
                        return False
                    data = res.get(f"{key}_variogram")
                    if data is None:
                        logger.warning(f"No data for {key} variogram - creating empty plot")
                        # Create empty DataFrame for plotting
                        import pandas as pd
                        data = pd.DataFrame({"distance": [], "gamma": [], "npairs": []})
                    else:
                        # Debug: log data shape to diagnose empty plots
                        logger.debug(f"{key} variogram data: {len(data)} rows, cols={list(data.columns)}")
                    
                    params = fits.get(key, {}).get(m_type)
                    logger.debug(f"{key} fitted params: {params}")
                    
                    canvas.plot_variogram(data, params, title, direction, normalize=normalize_flag)
                    
                    # Force immediate canvas update to prevent blank canvas
                    canvas.fig.canvas.draw_idle()
                    canvas.fig.canvas.flush_events()
                    
                    logger.debug(f"Successfully plotted {key} variogram")
                    plot_success = True
                    return True
                except RuntimeError as e:
                    if "QAction" in str(e) or "deleted" in str(e):
                        logger.debug(f"Ignoring stale QAction error during {key} plot: {e}")
                        # QAction errors are not plot failures - the plot may still be valid
                        plot_success = True
                        return True
                    else:
                        logger.error(f"RuntimeError during {key} plot: {e}", exc_info=True)
                        return False
                except Exception as e:
                    logger.error(f"Error plotting {key} variogram: {e}", exc_info=True)
                    # Try to show error message on canvas
                    try:
                        canvas.fig.clear()
                        ax = canvas.fig.add_subplot(111)
                        canvas._apply_theme(ax)
                        ax.text(0.5, 0.5, f"Error plotting {title}:\n{str(e)}",
                               ha='center', va='center', color='red', transform=ax.transAxes)
                        ax.set_title(title, fontsize=12, fontweight="bold", pad=10)
                        canvas._safe_draw()
                    except:
                        pass
                    return False

            logger.info("Updating variogram plots...")
            plot_results = []
            plot_results.append(("downhole", plot(self.canvas_downhole, "downhole", "Downhole (Nugget)", "downhole")))
            plot_results.append(("omni", plot(self.canvas_omni, "omni", "Omnidirectional", "omni")))
            plot_results.append(("major", plot(self.canvas_major, "major", "Major Direction", "major")))
            plot_results.append(("minor", plot(self.canvas_minor, "minor", "Minor Direction", "minor")))
            plot_results.append(("vertical", plot(self.canvas_vert, "vertical", "Vertical Direction", "vertical")))

            # 3D Model - with error handling
            plot_3d_success = False
            try:
                if not self._is_qt_object_deleted(self.canvas_3d):
                    self.canvas_3d.plot_3d_anisotropic_model(res.get('combined_3d_model'), "Estimation Model")
                    logger.debug("Successfully plotted 3D model")
                    plot_3d_success = True
            except RuntimeError as e:
                if "QAction" in str(e) or "deleted" in str(e):
                    logger.debug(f"Ignoring stale QAction error during 3D plot: {e}")
                    plot_3d_success = True  # QAction errors don't count as plot failures
                else:
                    logger.error(f"Error plotting 3D model: {e}", exc_info=True)

            # Check results - but wait for radial/cloud before final logging
            successful_plots = [name for name, success in plot_results if success] + (["3d"] if plot_3d_success else [])
            failed_plots = [name for name, success in plot_results if not success] + (["3d"] if not plot_3d_success else [])

            # Track radial and cloud plot results (these are handled after the main loop)
            radial_success = False
            cloud_success = False

            # Ensure current tab is refreshed and all canvases are repainted
            current_idx = self.tabs.currentIndex()
            if current_idx >= 0:
                current_widget = self.tabs.widget(current_idx)
                if hasattr(current_widget, '_safe_draw'):
                    try:
                        current_widget._safe_draw()
                        logger.debug(f"Refreshed current tab: {self.tabs.tabText(current_idx)}")
                    except Exception as e:
                        logger.debug(f"Could not refresh current tab: {e}")

            try:
                from PyQt6.QtWidgets import QApplication
                
                for canvas in [self.canvas_downhole, self.canvas_omni, self.canvas_major,
                              self.canvas_minor, self.canvas_vert, self.canvas_3d, 
                              self.canvas_radial, self.canvas_cloud]:
                    # Force matplotlib to render the figure
                    try:
                        canvas.fig.canvas.draw()
                        canvas.fig.canvas.flush_events()
                    except Exception:
                        pass
                    # Force Qt widget updates
                    if hasattr(canvas, 'repaint'):
                        canvas.repaint()
                    if hasattr(canvas, 'update'):
                        canvas.update()

                # Update the tab widget itself
                if hasattr(self.tabs, 'update'):
                    self.tabs.update()
                
                # CRITICAL: Force Qt to process all pending paint events
                # Without this, canvases may not render until user interacts
                QApplication.processEvents()
                logger.debug("Forced Qt event processing after plot updates")

            except Exception as e:
                logger.debug(f"Could not repaint canvases: {e}")
        except Exception as e:
            logger.error(f"Error in _update_plots: {e}", exc_info=True)
            # Don't raise - we want analysis to complete even if plotting fails
        
        # Radial (Azimuth ranges)
        # Extract ranges from directional variograms if available
        # Based on variogram3d.py: major uses azimuth 0 (North), minor uses azimuth 90 (East)
        azimuth_ranges = {}
        
        if 'major' in fits and m_type in fits.get('major', {}):
            major_params = fits['major'][m_type]
            major_range = major_params.get('range', 0)
            if major_range > 0:
                # Major direction: azimuth 0 (North) by default
                major_azimuth = res.get('major_azimuth', 0.0)
                azimuth_ranges[major_azimuth] = major_range
        
        if 'minor' in fits and m_type in fits.get('minor', {}):
            minor_params = fits['minor'][m_type]
            minor_range = minor_params.get('range', 0)
            if minor_range > 0:
                # Minor direction: azimuth 90 (East) by default
                minor_azimuth = res.get('minor_azimuth', 90.0)
                azimuth_ranges[minor_azimuth] = minor_range
        
        # If we have directional data, plot radial - with error handling
        try:
            if not self._is_qt_object_deleted(self.canvas_radial):
                if azimuth_ranges:
                    self.canvas_radial.plot_radial(azimuth_ranges, "Directional Ranges")
                    logger.debug("Successfully plotted radial")
                    radial_success = True
                else:
                    # Clear radial canvas if no data
                    self.canvas_radial.fig.clear()
                    ax = self.canvas_radial.fig.add_subplot(111)
                    colors = get_theme_colors()
                    ax.text(0.5, 0.5, 'No radial data available\n\nCompute variogram first',
                           ha='center', va='center', color=colors.TEXT_PRIMARY, fontsize=12,
                           transform=ax.transAxes)
                    ax.set_facecolor(colors.CARD_BG)
                    self.canvas_radial.fig.patch.set_facecolor(colors.PANEL_BG)
                    self.canvas_radial._safe_draw()
                    radial_success = True  # Empty plot is still successful
        except RuntimeError as e:
            if "QAction" in str(e) or "deleted" in str(e):
                logger.debug(f"Ignoring stale QAction error during radial plot: {e}")
                radial_success = True  # QAction errors don't count as plot failures
            else:
                logger.error(f"Error plotting radial: {e}", exc_info=True)
                # Don't raise - continue with other plots
        
        # Cloud (Sample) - with error handling
        try:
            if not self._is_qt_object_deleted(self.canvas_cloud):
                df = self.drillhole_data.sample(n=min(2000, len(self.drillhole_data)))
                dists, gammas = vg3d.plot_variogram_cloud(
                    df, xcol="X", ycol="Y", zcol="Z", vcol=self.var_combo.currentText(), max_pairs=5000
                )
                self.canvas_cloud.plot_variogram_cloud(dists, gammas)
                logger.debug("Successfully plotted cloud")
                cloud_success = True
        except RuntimeError as e:
            if "QAction" in str(e) or "deleted" in str(e):
                logger.debug(f"Ignoring stale QAction error during cloud plot: {e}")
                cloud_success = True  # QAction errors don't count as plot failures
            else:
                logger.error(f"Error plotting cloud: {e}", exc_info=True)
                # Don't raise - continue with other operations

        # Update final success tracking to include radial and cloud
        successful_plots += (["radial"] if radial_success else []) + (["cloud"] if cloud_success else [])
        failed_plots += (["radial"] if not radial_success else []) + (["cloud"] if not cloud_success else [])

        if failed_plots:
            logger.warning(f"Some plots failed: {failed_plots}. Successful: {successful_plots}")
        else:
            logger.info(f"All plots updated successfully: {successful_plots}")

    def _update_info(self):
        """Display variogram results in a clear, user-friendly format."""
        try:
            if not self.variogram_results:
                return

            mod = self.variogram_results.get('combined_3d_model', {})

            # Validate that combined model exists
            if not mod:
                logger.warning("No combined 3D model available - model building may have failed")
                if hasattr(self, 'info_text'):
                    self.info_text.setHtml("<p style='color: red;'>ERROR: Model building failed. No combined 3D model available.</p>")
                return

            lag_config = self.variogram_results.get('lag_config', {})
            fits = self.variogram_results.get('fitted_models', {})
            metadata = self.variogram_results.get('metadata', {})
            m_type = self.model_combo.currentText().lower()

            # === MAIN RESULTS SECTION ===
            nugget_val = mod.get('nugget', 0)
            # SILL SEMANTICS FIX: 'sill' is now PARTIAL sill (C), use 'total_sill' for C0+C
            partial_sill_val = mod.get('sill', 0)
            total_sill = mod.get('total_sill', nugget_val + partial_sill_val)  # Use stored total_sill
            major_range = mod.get('major_range', 0)
            minor_range = mod.get('minor_range', 0)
            vert_range = mod.get('vertical_range', 0)
            
            # Build clean header with key parameters
            html = """
