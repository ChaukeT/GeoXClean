    def _populate_combos(self):
        if self.drillhole_data is None: return
        
        # Safety check: ensure UI is initialized
        if not hasattr(self, 'var_combo'):
            return
        
        # Variables
        self.var_combo.blockSignals(True)
        self.var_combo.clear()
        nums = self.drillhole_data.select_dtypes(include=[np.number]).columns
        ignore = {
            'X','Y','Z','HOLEID','FROM','TO','LENGTH','GLOBAL_INTERVAL_ID',
            # Compositing metadata columns (not geological properties)
            'SAMPLE_COUNT','TOTAL_MASS','TOTAL_LENGTH','SUPPORT','IS_PARTIAL',
            'METHOD','WEIGHTING','ELEMENT_WEIGHTS','MERGED_PARTIAL','MERGED_PARTIAL_AUTO'
        }
        valid = [c for c in nums if c.upper() not in ignore]
        self.var_combo.addItems(sorted(valid))
        self.var_combo.blockSignals(False)
            
        # Domains
        self.domain_combo.clear()
        self.domain_combo.addItem("All Data")
        # Find categorical columns
        cats = [c for c in self.drillhole_data.columns if self.drillhole_data[c].dtype == object]
        for c in cats:
            try:
                # Check if column contains hashable values (skip dict/list columns)
                # Try to get unique count - will fail if column contains unhashable types
                unique_count = self.drillhole_data[c].nunique()
                if unique_count < 20:  # Limit domain count
                    self.domain_combo.addItem(c)
            except (TypeError, ValueError):
                # Skip columns with unhashable types (dicts, lists, etc.)
                continue

