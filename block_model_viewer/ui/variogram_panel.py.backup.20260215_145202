    def get_panel_settings(self) -> Optional[Dict[str, Any]]:
        """Get panel settings for project save.
        
        Returns:
            Dictionary of all user-configurable settings, or None if no settings.
        """
        try:
            from .panel_settings_utils import get_safe_widget_value
            
            settings = {}
            
            # Configuration group
            settings['variable'] = get_safe_widget_value(self, 'var_combo')
            settings['holeid'] = get_safe_widget_value(self, 'hole_combo')
            settings['domain'] = get_safe_widget_value(self, 'domain_combo')
            settings['nlag'] = get_safe_widget_value(self, 'nlag_spin')
            settings['lag_dist'] = get_safe_widget_value(self, 'lag_dist_spin')
            settings['lag_tol'] = get_safe_widget_value(self, 'lag_tol_spin')
            settings['auto_lags'] = get_safe_widget_value(self, 'auto_lags_checkbox')
            
            # Data source
            if hasattr(self, 'data_source_composited'):
                settings['data_source'] = 'composited' if self.data_source_composited.isChecked() else 'raw'
            
            # Model fitting group
            settings['model_type'] = get_safe_widget_value(self, 'model_combo')
            settings['structures'] = get_safe_widget_value(self, 'struct_spin')
            settings['global_nugget_enabled'] = get_safe_widget_value(self, 'global_nugget_checkbox')
            settings['global_nugget_value'] = get_safe_widget_value(self, 'global_nugget_spin')
            settings['normalize_y'] = get_safe_widget_value(self, 'normalize_y_checkbox')
            
            # Directional analysis group
            settings['manual_azimuth'] = get_safe_widget_value(self, 'manual_azimuth_checkbox')
            settings['major_azimuth'] = get_safe_widget_value(self, 'major_azimuth_spin')
            settings['minor_azimuth'] = get_safe_widget_value(self, 'minor_azimuth_spin')
            
            # Filter out None values
            settings = {k: v for k, v in settings.items() if v is not None}
            
            return settings if settings else None
            
        except Exception as e:
            logger.warning(f"Could not save variogram panel settings: {e}")
            return None

    def apply_panel_settings(self, settings: Dict[str, Any]) -> None:
        """Apply panel settings from project load.
        
        Args:
            settings: Dictionary of previously saved settings
        """
        if not settings:
            return
            
        try:
            from .panel_settings_utils import set_safe_widget_value
            
            # Configuration group
            set_safe_widget_value(self, 'var_combo', settings.get('variable'))
            set_safe_widget_value(self, 'hole_combo', settings.get('holeid'))
            set_safe_widget_value(self, 'domain_combo', settings.get('domain'))
            set_safe_widget_value(self, 'nlag_spin', settings.get('nlag'))
            set_safe_widget_value(self, 'lag_dist_spin', settings.get('lag_dist'))
            set_safe_widget_value(self, 'lag_tol_spin', settings.get('lag_tol'))
            set_safe_widget_value(self, 'auto_lags_checkbox', settings.get('auto_lags'))
            
            # Data source
            if 'data_source' in settings:
                if settings['data_source'] == 'composited' and hasattr(self, 'data_source_composited'):
                    self.data_source_composited.setChecked(True)
                elif settings['data_source'] == 'raw' and hasattr(self, 'data_source_raw'):
                    self.data_source_raw.setChecked(True)
            
            # Model fitting group
            set_safe_widget_value(self, 'model_combo', settings.get('model_type'))
            set_safe_widget_value(self, 'struct_spin', settings.get('structures'))
            set_safe_widget_value(self, 'global_nugget_checkbox', settings.get('global_nugget_enabled'))
            set_safe_widget_value(self, 'global_nugget_spin', settings.get('global_nugget_value'))
            set_safe_widget_value(self, 'normalize_y_checkbox', settings.get('normalize_y'))
            
            # Directional analysis group
            set_safe_widget_value(self, 'manual_azimuth_checkbox', settings.get('manual_azimuth'))
            set_safe_widget_value(self, 'major_azimuth_spin', settings.get('major_azimuth'))
            set_safe_widget_value(self, 'minor_azimuth_spin', settings.get('minor_azimuth'))
            
            # Trigger UI updates if needed
            if settings.get('global_nugget_enabled') and hasattr(self, '_on_global_nugget_changed'):
                self._on_global_nugget_changed()
            if settings.get('manual_azimuth') and hasattr(self, '_on_manual_azimuth_changed'):
                self._on_manual_azimuth_changed()
            if settings.get('auto_lags') and hasattr(self, '_on_auto_lags_changed'):
                self._on_auto_lags_changed()
                
            logger.info("Restored variogram panel settings from project")
            
        except Exception as e:
            logger.warning(f"Could not restore variogram panel settings: {e}")