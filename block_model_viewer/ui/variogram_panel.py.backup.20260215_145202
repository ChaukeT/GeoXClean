    def _connect_registry(self):
        """Connect to the DataRegistry signals.
        
        FIX: Added null checks for signal properties before calling .connect().
        Signal properties return None if _signals is not initialized.
        """
        try:
            self.registry = self.get_registry()
            if not self.registry:
                logger.warning("VariogramPanel: DataRegistry not available")
                return
            
            # FIX: Check if signal is available before connecting
            drillhole_signal = self.registry.drillholeDataLoaded
            if drillhole_signal is not None:
                drillhole_signal.connect(self._on_data_loaded)
                logger.debug("VariogramPanel: Connected to drillholeDataLoaded signal")
            else:
                logger.warning("VariogramPanel: drillholeDataLoaded signal not available")
            
            # Connect declustering signal if available
            declustering_signal = getattr(self.registry, 'declusteringResultsLoaded', None)
            if declustering_signal is not None:
                declustering_signal.connect(self._on_declustering_results_loaded)
                logger.debug("VariogramPanel: Connected to declusteringResultsLoaded signal")
            
            # Initial load - check for declustered data first (handles lazy panel creation)
            declust = self.registry.get_data("declustering_results")
            if declust:
                self._on_declustering_results_loaded(declust)
            else:
                data = self.registry.get_drillhole_data()
                if data is not None:
                    self._on_data_loaded(data)
        except Exception as exc:
            self.registry = None
            logger.warning(f"VariogramPanel: DataRegistry connection failed: {exc}", exc_info=True)

    def _on_declustering_results_loaded(self, results):
        """Handle new declustering results."""
        if not results or 'weighted_dataframe' not in results:
            return

        # Validate dataframe
        df = results.get('weighted_dataframe')
        if df is None or not isinstance(df, pd.DataFrame) or df.empty:
            logger.warning("Invalid declustering results - no valid weighted_dataframe")
            return

        # Log receipt
        logger.info("Received declustered data for variogram analysis")

        # Store and use
        self.drillhole_data = ensure_xyz_columns(df)
        self._populate_combos()
        
        # Update data source UI to show "Declustered" is active
        if hasattr(self, 'data_source_status_label'):
            self.data_source_status_label.setText("Using: ✅ Declustered data")
            self.data_source_status_label.setStyleSheet("font-size: 9px; color: #4CAF50;")
            
        # Ensure run button enabled
        if hasattr(self, 'run_btn'):
            self.run_btn.setEnabled(True)
            
        # Flash/notify user
        if self.isVisible():
            self.info_text.setHtml("<p style='color: #4CAF50'><b>New Data Loaded:</b><br>Declustered weights available.</p>")

