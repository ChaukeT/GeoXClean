class VariogramCanvas(FigureCanvas):
    """Custom Matplotlib canvas for Variogram plots."""

    def __init__(self, parent=None, width=8, height=6, dpi=100):
        self.fig = Figure(figsize=(width, height), dpi=dpi)
        colors = get_theme_colors()
        self.fig.patch.set_facecolor(colors.CARD_BG)
        super().__init__(self.fig)
        self.setParent(parent)
        self.setSizePolicy(QSizePolicy.Policy.Expanding, QSizePolicy.Policy.Expanding)
        self.setMinimumSize(400, 300)
        self.updateGeometry()

    def clear_figure(self):
        """Clear the figure safely."""
        try:
            self.fig.clear()
            self._safe_draw()
        except Exception as e:
            logger.debug(f"Figure clear failed: {e}")
            # If clearing fails completely, just continue without clearing
            pass
    
    def _safe_draw(self):
        """Draw the figure with protection against deleted QAction errors.
        
        The NavigationToolbar may have been deleted but the canvas still has
        event connections to it. When draw() fires events, accessing deleted
        QActions causes RuntimeError. This wrapper catches and logs such errors.
        """
        try:
            # Debug layout issues
            if self.width() < 10 or self.height() < 10:
                logger.warning(f"Canvas draw called on small/invisible widget: {self.width()}x{self.height()}")
            
            # Use draw_idle() for thread-safe rendering, then flush to ensure it happens
            self.draw_idle()
            self.flush_events()
        except RuntimeError as e:
            if "QAction" in str(e) or "deleted" in str(e):
                logger.debug(f"Ignoring stale QAction error during draw: {e}")
                # Try alternative draw methods
                try:
                    # Force a blit update if available
                    if hasattr(self, 'blit'):
                        self.blit(self.fig.bbox)
                    # Force Qt repaint
                    self.update()
                    self.repaint()
                except Exception:
                    pass
            else:
                raise
        except Exception as e:
            logger.debug(f"Draw failed with {type(e).__name__}: {e}")
            # Fallback: force Qt widget repaint
            try:
                self.update()
                self.repaint()
            except Exception:
                pass

    def _apply_theme(self, ax, is_3d: bool = False):
        """Apply current theme colors to matplotlib axes."""
        colors = get_theme_colors()
        ax.set_facecolor(colors.CARD_BG)
        ax.tick_params(colors=colors.TEXT_PRIMARY)
        ax.xaxis.label.set_color(colors.TEXT_PRIMARY)
        ax.yaxis.label.set_color(colors.TEXT_PRIMARY)
        if is_3d:
            ax.zaxis.label.set_color(colors.TEXT_PRIMARY)
        ax.title.set_color(colors.TEXT_PRIMARY)
        for spine in ax.spines.values():
            spine.set_color(colors.BORDER)
        ax.grid(True, color=colors.BORDER, linestyle="--", alpha=0.5)

    def plot_variogram(
        self,
        variogram_data: pd.DataFrame,
        fitted_params: Optional[Dict] = None,
        title: str = "Variogram",
        direction: str = "omni",
        normalize: bool = False,
    ):

        try:
            self.fig.clear()
        except RuntimeError as e:
            if "QAction" in str(e) or "deleted" in str(e):
                logger.debug(f"Ignored QAction error during fig.clear(): {e}")
            else:
                raise

        ax = self.fig.add_subplot(111)
        self._apply_theme(ax)
        
        # Handle empty or missing data gracefully
        if variogram_data is None or len(variogram_data) == 0:
            ax.text(0.5, 0.5, f"No data available for {title}\n\n"
                    "Possible causes:\n"
                    "• No HOLEID column found (for downhole)\n"
                    "• Not enough samples in this direction\n"
                    "• FROM/TO depth columns missing",
                    ha='center', va='center', color='#ff9800', fontsize=10,
                    transform=ax.transAxes, wrap=True)
            ax.set_title(title, fontsize=12, fontweight="bold", pad=10)
            self._safe_draw()
            return
        
        # Check for required columns
        required_cols = ["distance", "gamma", "npairs"]
        missing_cols = [c for c in required_cols if c not in variogram_data.columns]
        if missing_cols:
            ax.text(0.5, 0.5, f"Missing columns: {missing_cols}",
                    ha='center', va='center', color='red', transform=ax.transAxes)
            ax.set_title(title, fontsize=12, fontweight="bold", pad=10)
            self._safe_draw()
            return

        dist = variogram_data["distance"].values
        gamma = variogram_data["gamma"].values
        npairs = variogram_data["npairs"].values
        
        # Handle empty arrays
        if len(dist) == 0 or len(gamma) == 0:
            ax.text(0.5, 0.5, f"No valid lags for {title}\n\n"
                    "Try:\n"
                    "• Increasing lag tolerance\n"
                    "• Checking data coordinates",
                    ha='center', va='center', color='#ff9800', fontsize=10,
                    transform=ax.transAxes, wrap=True)
            ax.set_title(title, fontsize=12, fontweight="bold", pad=10)
            self._safe_draw()
            return

        # Size points by pair count with more explicit visual feedback
        sizes = 30
        if npairs.size > 0 and npairs.max() > 0:
            # Normalize sizes: minimum 20, maximum 120, based on pair count
            min_size, max_size = 20, 120
            sizes = min_size + ((npairs / npairs.max()) * (max_size - min_size))

        # Optional normalization of Y-axis (divide by sill/peak) to compare shapes
        norm_factor = 1.0
        if normalize:
            if fitted_params:
                nug = fitted_params.get("nugget", 0.0)
                psill = fitted_params.get("sill", 0.0)
                norm_factor = max(nug + psill, 1e-9)
            else:
                norm_factor = max(np.nanmax(gamma), 1e-9)

        gamma_plot = gamma / norm_factor if normalize else gamma

        # Plot experimental points with pair count information
        scatter = ax.scatter(dist, gamma_plot, s=sizes, alpha=0.8, 
                           label="Experimental", color="#4fc3f7", 
                           edgecolors="white", linewidth=0.5, zorder=3)
        
        # Add pair count annotations for key points (every 3rd point to avoid clutter)
        for i in range(0, len(dist), max(1, len(dist) // 5)):  # Show ~5 annotations max
            if i < len(npairs) and npairs[i] > 0:
                ax.annotate(f'{int(npairs[i])}', 
                          (dist[i], gamma_plot[i]),
                          xytext=(5, 5), textcoords='offset points',
                          fontsize=8, alpha=0.7, color='#4fc3f7',
                          bbox=dict(boxstyle='round,pad=0.2', facecolor='black', alpha=0.6))
        
        # Add pair count info to title for user awareness
        if npairs.size > 0:
            total_pairs = int(np.sum(npairs))
            avg_pairs_per_lag = int(np.mean(npairs[npairs > 0])) if np.sum(npairs > 0) > 0 else 0
            title = f"{title} ({total_pairs} total pairs, ~{avg_pairs_per_lag} avg/lag)"

        if fitted_params:
            m_type = fitted_params.get("model_type", "spherical")
            nug = fitted_params["nugget"]
            psill = fitted_params.get("sill", 0.0)
            rng = fitted_params["range"]
            tot_sill = fitted_params.get("total_sill", nug + psill)

            # Generate model curve
            x_model = np.linspace(0, dist.max() * 1.1 if dist.size else 1.0, 100)
            
            # Check for nested model
            nested = fitted_params.get("nested")
            if nested and nested.get("n_structures", 1) > 1:
                # Plot nested model with individual structures
                structures = nested.get("structures", [])
                n_nug = nested.get("nugget", nug)
                
                # Plot each structure as dashed line
                colors = ["#81c784", "#64b5f6", "#ffb74d"]  # Green, Blue, Orange
                y_total = np.full_like(x_model, n_nug)
                
                for i, struct in enumerate(structures):
                    s_type = struct.get("model_type", m_type)
                    s_contrib = struct.get("contribution", 0)
                    s_range = struct.get("range_major", rng)
                    
                    vg = vg3d.Variogram3D()
                    y_struct = vg.evaluate_model(x_model, s_type, 0, s_contrib, s_range)
                    y_total += y_struct
                    
                    # Plot individual structure contribution
                    y_struct_plot = (n_nug + y_struct) / norm_factor if normalize else (n_nug + y_struct)
                    ax.plot(x_model, y_struct_plot, color=colors[i % len(colors)], 
                           linewidth=1.5, linestyle="--", alpha=0.6,
                           label=f"Struct {i+1}: R={s_range:.0f}m")
                
                # Plot total nested model
                y_model_plot = y_total / norm_factor if normalize else y_total
                ax.plot(x_model, y_model_plot, color="#ffb74d", linewidth=2.5, 
                       label=f"Nested {m_type.title()}", zorder=2)
            else:
                # Single structure model
                vg = vg3d.Variogram3D()
                y_model = vg.evaluate_model(x_model, m_type, nug, psill, rng)
                y_model_plot = y_model / norm_factor if normalize else y_model
                ax.plot(x_model, y_model_plot, color="#ffb74d", linewidth=2.5, 
                       label=f"{m_type.title()} Model", zorder=2)
            
            # Reference lines with clear geostatistical notation
            ax.axhline(y=(nug / norm_factor) if normalize else nug, color="#9e9e9e", linestyle=":", alpha=0.6, label=f"C₀={nug:.2f}")
            ax.axhline(y=(tot_sill / norm_factor) if normalize else tot_sill, color="#ef5350", linestyle="--", alpha=0.6, label=f"C₀+C={tot_sill:.2f}")
            ax.axvline(x=rng, color="#66bb6a", linestyle="--", alpha=0.6, label=f"Range ({rng:.1f})")

        colors = get_theme_colors()
        ax.set_xlabel("Distance (h)")
        ax.set_ylabel("Semivariance (γ)")
        ax.set_title(title, fontsize=12, fontweight="bold", pad=10)
        ax.legend(loc="lower right", facecolor=colors.CARD_BG, edgecolor=colors.BORDER, labelcolor=colors.TEXT_PRIMARY, fontsize=8)
        
        # Log limits to debug "blank plot" issues
        logger.debug(f"Plot '{title}' limits: X={ax.get_xlim()}, Y={ax.get_ylim()}")
        
        try:
            # Use basic tight_layout without rect to avoid annoying warnings
            self.fig.tight_layout()
        except Exception as e:
            logger.debug(f"tight_layout failed for {title}: {e}")
            
        self._safe_draw()

    def plot_3d_anisotropic_model(self, combined_model: Dict[str, Any], title: str = "3D Model"):
        """Visualizes the 3D Ellipsoid (Rotated correctly in 3D space) and directional curves."""
        self.fig.clear()
        
        if not combined_model:
            ax = self.fig.add_subplot(111)
            self._apply_theme(ax)
            colors = get_theme_colors()
            ax.text(0.5, 0.5, "No 3D model available.", ha='center', va='center', color=colors.TEXT_PRIMARY)
            self._safe_draw()
            return
        
        # 2x2 Grid with better spacing
        gs = self.fig.add_gridspec(2, 2, hspace=0.4, wspace=0.35, 
                                   left=0.08, right=0.95, top=0.92, bottom=0.1)
        
        # --- 1. Directional Curves (Top-Left) ---
        ax1 = self.fig.add_subplot(gs[0, 0])
        self._apply_theme(ax1)
        
        maj_r = combined_model.get("major_range", 100)
        min_r = combined_model.get("minor_range", 100)
        vert_r = combined_model.get("vertical_range", 100)
        nug = combined_model.get("nugget", 0)
        # SILL SEMANTICS FIX: 'sill' is now partial sill (C), use directly
        psill = combined_model.get("sill", 1)  # Partial sill (C)
        total_sill = combined_model.get("total_sill", nug + psill)  # Total sill (C0 + C)
        m_type = combined_model.get("model_type", "spherical")
        
        max_x = max(maj_r, min_r, vert_r) * 1.2
        x = np.linspace(0, max_x, 100)
        
        vg = vg3d.Variogram3D()
        # evaluate_model expects (dist, model_type, nugget, partial_sill, range)
        y_maj = vg.evaluate_model(x, m_type, nug, psill, maj_r)
        y_min = vg.evaluate_model(x, m_type, nug, psill, min_r)
        y_vert = vg.evaluate_model(x, m_type, nug, psill, vert_r)
        
        colors = get_theme_colors()
        ax1.plot(x, y_maj, 'g-', lw=2, label='Major')
        ax1.plot(x, y_min, 'b-', lw=2, label='Minor')
        ax1.plot(x, y_vert, 'r-', lw=2, label='Vertical')
        ax1.set_title("Directional Models", color=colors.TEXT_PRIMARY, fontweight='bold')
        ax1.legend(facecolor=colors.CARD_BG, labelcolor=colors.TEXT_PRIMARY, fontsize=8)

        # --- 2. Rotated 3D Ellipsoid (Top-Right) ---
        ax2 = self.fig.add_subplot(gs[0, 1], projection='3d')
        self._apply_theme(ax2, is_3d=True)
        ax2.set_facecolor(colors.CARD_BG)
        
        # 1. Generate Axis-Aligned Unit Sphere
        u = np.linspace(0, 2 * np.pi, 20)
        v = np.linspace(0, np.pi, 10)
        x = np.outer(np.cos(u), np.sin(v))
        y = np.outer(np.sin(u), np.sin(v))
        z = np.outer(np.ones_like(u), np.cos(v))
        
        # 2. Scale by Ranges
        x *= maj_r
        y *= min_r
        z *= vert_r
        
        # 3. Rotate Coordinates (ZXZ Convention usually, or Z-Y-X)
        # Assuming: Azimuth (Z rot), Dip (X rot), Pitch (Y rot)
        az = np.radians(combined_model.get("azimuth", 0.0))
        dip = np.radians(combined_model.get("dip", 0.0))
        pitch = np.radians(combined_model.get("plunge", 0.0)) # Or plunge
        
        # Rotation Matrix (Simple Azimuth/Dip for visual context)
        # Rotate around Y (Dip) then Z (Azimuth) - Mining convention varies, this is standard GSLIB
        
        # Flatten for rotation
        coords = np.vstack([x.flatten(), y.flatten(), z.flatten()])
        
        # Rotate Dip (around X axis - geology convention positive down)
        Rx = np.array([
            [1, 0, 0],
            [0, np.cos(dip), -np.sin(dip)],
            [0, np.sin(dip), np.cos(dip)]
        ])
        
        # Rotate Azimuth (around Z axis)
        Rz = np.array([
            [np.cos(az), -np.sin(az), 0],
            [np.sin(az), np.cos(az), 0],
            [0, 0, 1]
        ])
        
        # Apply Rotation: Rz * Rx * v
        rotated = Rz @ (Rx @ coords)
        
        # Reshape back
        shape = x.shape
        X_rot = rotated[0, :].reshape(shape)
        Y_rot = rotated[1, :].reshape(shape)
        Z_rot = rotated[2, :].reshape(shape)
        
        ax2.plot_wireframe(X_rot, Y_rot, Z_rot, color='#4fc3f7', alpha=0.4, linewidth=0.5)
        
        # Add Axes Markers (Scaled)
        m_lim = max(maj_r, min_r, vert_r) * 1.1
        ax2.plot([-m_lim, m_lim], [0,0], [0,0], 'w--', lw=0.5, alpha=0.3) # East-West
        ax2.plot([0,0], [-m_lim, m_lim], [0,0], 'w--', lw=0.5, alpha=0.3) # North-South
        ax2.plot([0,0], [0,0], [-m_lim, m_lim], 'w--', lw=0.5, alpha=0.3) # Vertical
        
        ax2.set_xlim(-m_lim, m_lim); ax2.set_ylim(-m_lim, m_lim); ax2.set_zlim(-m_lim, m_lim)
        ax2.set_title("Anisotropy (Rotated)", color=colors.TEXT_PRIMARY, fontweight='bold')
        ax2.set_xlabel("E"); ax2.set_ylabel("N"); ax2.set_zlabel("Z")

        # --- 3. Parameters Table (Bottom Row) ---
        ax3 = self.fig.add_subplot(gs[1, :])
        ax3.axis('off')

        aniso_min = min_r / maj_r if maj_r > 0 else 1.0
        aniso_vert = vert_r / maj_r if maj_r > 0 else 1.0

        rows = [
            ["Parameter", "Value", "Description"],
            ["Nugget (C₀)", f"{nug:.3f}", "Short-range variability"],
            ["Partial Sill (C)", f"{psill:.3f}", "Structured variance"],
            ["Total Sill (C₀+C)", f"{total_sill:.3f}", "Total variance"],
            ["Major Range", f"{maj_r:.1f} m", "Primary continuity direction"],
            ["Minor Ratio", f"{aniso_min:.2f}", f"Range: {min_r:.1f} m"],
            ["Vertical Ratio", f"{aniso_vert:.2f}", f"Range: {vert_r:.1f} m"],
            ["Orientation", f"Az: {np.degrees(az):.0f}° Dip: {np.degrees(dip):.0f}°", "Ellipsoid rotation"]
        ]

        table = ax3.table(cellText=rows, loc='center', cellLoc='left',
                          colWidths=[0.25, 0.25, 0.5], bbox=[0, 0, 1, 1])
        table.auto_set_font_size(False)
        table.set_fontsize(9)
        table.scale(1, 1.5)

        for key, cell in table.get_celld().items():
            cell.set_facecolor(colors.CARD_BG); cell.set_text_props(color=colors.TEXT_PRIMARY); cell.set_edgecolor(colors.BORDER)
            if key[0] == 0:
                cell.set_facecolor(colors.ELEVATED_BG); cell.set_text_props(weight='bold', color=colors.ACCENT_PRIMARY)

        self.fig.suptitle(title, color=colors.TEXT_PRIMARY, fontsize=14, fontweight='bold', y=0.98)
        try:
            self.fig.tight_layout(rect=[0, 0, 1, 0.96])
        except Exception:
            pass  # Suppress tight_layout warning for incompatible axes
        self._safe_draw()

    def plot_variogram_cloud(self, dists, gammas):
        self.fig.clear()
        ax = self.fig.add_subplot(111)
        self._apply_theme(ax)
        
        colors = get_theme_colors()
        # Hexbin for density if many points
        if len(dists) > 5000:
            hb = ax.hexbin(dists, gammas, gridsize=40, cmap='Blues', mincnt=1)
            self.fig.colorbar(hb, ax=ax, label='Count')
        else:
            ax.scatter(dists, gammas, s=5, alpha=0.4, color=colors.ACCENT_PRIMARY, edgecolors='none')

        ax.set_title(f"Variogram Cloud ({len(dists)} pairs)", color=colors.TEXT_PRIMARY, fontweight='bold', pad=10)
        ax.set_xlabel("Distance"); ax.set_ylabel("Semivariance")
        self.fig.tight_layout(rect=[0.05, 0.05, 0.95, 0.95])
        self._safe_draw()

    def plot_radial(self, azimuth_ranges, title="Radial Ranges"):
        """Rose diagram of ranges."""
        colors = get_theme_colors()
        self.fig.clear()
        ax = self.fig.add_subplot(111, polar=True)
        ax.set_facecolor(colors.CARD_BG); self.fig.patch.set_facecolor(colors.PANEL_BG)
        ax.tick_params(colors=colors.TEXT_PRIMARY); ax.spines['polar'].set_color(colors.BORDER)

        # Data
        azs = np.array(list(azimuth_ranges.keys()))
        rngs = np.array(list(azimuth_ranges.values()))

        # Sort
        idx = np.argsort(azs)
        azs = azs[idx]; rngs = rngs[idx]

        # Convert azimuth (deg) to polar theta (rad, 0=East, CCW)
        # Azimuth: 0=N, 90=E. Polar: 0=E, 90=N.
        theta = np.deg2rad(90 - azs)

        # Plot bars
        bars = ax.bar(theta, rngs, width=0.5, alpha=0.7, edgecolor=colors.TEXT_PRIMARY)

        # Compass labels
        ax.set_theta_zero_location('N')
        ax.set_theta_direction(-1)
        # Set tick positions first, then labels (fixes matplotlib warning)
        tick_positions = np.linspace(0, 2*np.pi, 8, endpoint=False)
        ax.set_xticks(tick_positions)
        ax.set_xticklabels(['N','NE','E','SE','S','SW','W','NW'], color=colors.TEXT_PRIMARY)
        ax.set_title(title, color=colors.TEXT_PRIMARY, pad=15, fontweight='bold')
        
        self.fig.tight_layout(rect=[0.05, 0.05, 0.95, 0.95])
        self._safe_draw()

