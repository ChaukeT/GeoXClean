        header_layout.addLayout(title_layout, 1)

        self.auto_btn = QPushButton("✨ Auto-Detect")
        self.auto_btn.setCursor(Qt.CursorShape.PointingHandCursor)
        self.auto_btn.setStyleSheet(f"""
            QPushButton {{
                background-color: white; color: #065f46;
                border: none; border-radius: 5px; padding: 6px 14px;
                font-size: 9pt; font-weight: 700;
            }}
            QPushButton:hover {{ background-color: {ModernColors.TEXT_PRIMARY}; }}
        """)
        self.auto_btn.clicked.connect(self._auto_detect_all)
        header_layout.addWidget(self.auto_btn)
        layout.addWidget(self.header)
        
        # Scrollable Body
        scroll = QScrollArea()
        scroll.setWidgetResizable(True)
        scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarPolicy.ScrollBarAlwaysOff)
        scroll.setStyleSheet("QScrollArea { background: transparent; border: none; }")
        
        scroll_content = QWidget()
        scroll_layout = QVBoxLayout(scroll_content)
        scroll_layout.setSpacing(6)
        scroll_layout.setContentsMargins(0, 0, 4, 0)
        
        # Collapsible Preview
        self.preview_header = QPushButton("📋 Data Preview ▸")
        self.preview_header.setCheckable(True)
        self.preview_header.setCursor(Qt.CursorShape.PointingHandCursor)
        self.preview_header.setStyleSheet(f"""
            QPushButton {{
                background-color: {colors.ELEVATED_BG}; color: {colors.TEXT_PRIMARY};
                border: 1px solid {colors.BORDER}; border-radius: 4px;
                padding: 6px 10px; text-align: left; font-weight: 600; font-size: 9pt;
            }}
            QPushButton:hover {{ background-color: {colors.CARD_HOVER}; }}
            QPushButton:checked {{ border-color: {colors.SUCCESS}; }}
        """)
        scroll_layout.addWidget(self.preview_header)
        
        self.preview_widget = QWidget()
        preview_layout = QVBoxLayout(self.preview_widget)
        preview_layout.setContentsMargins(6, 4, 6, 4)
        preview_layout.setSpacing(4)
        
        max_cols = 8
        preview_cols = list(self.df.columns[:max_cols])
        
        self.preview_table = QTableWidget()
        self.preview_table.setRowCount(3)
        self.preview_table.setColumnCount(len(preview_cols))
        self.preview_table.setHorizontalHeaderLabels(preview_cols)
        self.preview_table.horizontalHeader().setSectionResizeMode(QHeaderView.ResizeMode.Stretch)
        self.preview_table.verticalHeader().setVisible(False)
        self.preview_table.setAlternatingRowColors(True)
        self.preview_table.setStyleSheet(f"""
            QTableWidget {{
                background-color: {colors.ELEVATED_BG}; color: {colors.TEXT_PRIMARY};
                border: 1px solid {colors.BORDER}; border-radius: 4px;
                gridline-color: {colors.DIVIDER};
            }}
            QTableWidget::item {{ padding: 4px; }}
            QTableWidget::item:alternate {{ background-color: {colors.CARD_BG}; }}
            QHeaderView::section {{
                background-color: {colors.ELEVATED_BG}; color: {colors.TEXT_PRIMARY};
                padding: 6px; border: none; border-bottom: 2px solid {colors.SUCCESS};
                font-weight: 600; font-size: 7pt;
            }}
        """)
        
