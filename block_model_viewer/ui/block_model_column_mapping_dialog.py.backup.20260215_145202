        # Update property section labels and buttons
        if hasattr(self, 'info_label_prop'):
            self.info_label_prop.setStyleSheet(f"color: {colors.TEXT_SECONDARY}; font-size: 8pt;")

        if hasattr(self, 'sel_all') and hasattr(self, 'desel_all'):
            button_style = f"""
                QPushButton {{
                    background-color: {colors.CARD_HOVER}; color: {colors.TEXT_PRIMARY};
