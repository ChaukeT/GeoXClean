            for j, col in enumerate(preview_cols):
                value = str(self.df[col].iloc[i])[:20]
                item = QTableWidgetItem(value)
                item.setFlags(item.flags() & ~Qt.ItemFlag.ItemIsEditable)
                self.preview_table.setItem(i, j, item)
        
        self.preview_table.setFixedHeight(80)
        preview_layout.addWidget(self.preview_table)
        
        if len(self.df.columns) > max_cols:
            self.more_label = QLabel(f"+ {len(self.df.columns) - max_cols} more columns")
            self.more_label.setStyleSheet(f"color: {colors.TEXT_DISABLED}; font-size: 7pt; font-style: italic;")
            preview_layout.addWidget(self.more_label)

        self.preview_widget.setVisible(False)  # Collapsed by default
        scroll_layout.addWidget(self.preview_widget)

        self.preview_header.toggled.connect(lambda checked: (
            self.preview_widget.setVisible(checked),
            self.preview_header.setText("📋 Data Preview ▾" if checked else "📋 Data Preview ▸")
        ))

        # Section 1: Coordinates (Required)
        self.coord_group = QGroupBox("🎯 Coordinates (Required)")
        self.coord_group.setStyleSheet(f"""
            QGroupBox {{
                color: {colors.TEXT_PRIMARY}; font-weight: 600; font-size: 10pt;
                background-color: {colors.ELEVATED_BG};
                border: 1px solid {colors.BORDER}; border-radius: 4px;
                margin-top: 6px; padding-top: 10px;
            }}
