"""
Column Mapping Dialog for Block Model Data - Clean, Functional Design.
Allows users to map their CSV columns to required block model fields.
"""

from __future__ import annotations

import logging
from typing import Optional, Dict, Set
import pandas as pd

from PyQt6.QtWidgets import (
    QDialog, QVBoxLayout, QHBoxLayout, QLabel, QPushButton,
    QComboBox, QGroupBox, QTableWidget, QTableWidgetItem, QHeaderView,
    QScrollArea, QWidget, QFrame
)
from PyQt6.QtCore import Qt, pyqtSignal
from PyQt6.QtGui import QFont, QCursor
from .modern_styles import get_theme_colors, ModernColors

logger = logging.getLogger(__name__)


class BlockMappingRow(QFrame):
    """Clean row for mapping a block model field."""

    def __init__(self, field_key: str, field_label: str, required: bool,
                 columns: list, auto_match: Optional[str] = None, parent=None):
        super().__init__(parent)
        self.field_key = field_key
        self.field_label = field_label
        self.required = required
        self.columns = columns

        self._setup_ui(columns, auto_match)

    def _get_row_stylesheet(self) -> str:
        """Generate theme-aware stylesheet for the row."""
        colors = get_theme_colors()
        return f"""
            #BlockMappingRow {{
                background-color: {colors.CARD_BG};
                border: 1px solid {colors.BORDER};
                border-radius: 4px;
            }}
            #BlockMappingRow:hover {{
                background-color: {colors.CARD_HOVER};
                border-color: {colors.BORDER_LIGHT};
            }}
        """

    def _get_combo_stylesheet(self) -> str:
        """Generate theme-aware stylesheet for the combo box."""
        colors = get_theme_colors()
        return f"""
            QComboBox {{
                background-color: {colors.ELEVATED_BG};
                color: {colors.TEXT_PRIMARY};
                border: 1px solid {colors.BORDER};
                border-radius: 4px;
                padding: 2px 6px;
                font-size: 9pt;
                font-weight: 500;
            }}
            QComboBox:hover {{
                background-color: {colors.CARD_HOVER};
                border-color: {colors.BORDER_LIGHT};
            }}
            QComboBox QAbstractItemView {{
                background-color: {colors.ELEVATED_BG};
                color: {colors.TEXT_PRIMARY};
                border: 1px solid {colors.BORDER};
                selection-background-color: {colors.SUCCESS};
            }}
        """
    
    def _setup_ui(self, columns: list, auto_match: Optional[str]):
        colors = get_theme_colors()
        self.setFixedHeight(28)
        self.setObjectName("BlockMappingRow")

        self.setStyleSheet(self._get_row_stylesheet())

        layout = QHBoxLayout(self)
        layout.setContentsMargins(8, 3, 8, 3)
        layout.setSpacing(8)

        # Status indicator
        self.status_indicator = QFrame()
        self.status_indicator.setFixedSize(6, 6)
        layout.addWidget(self.status_indicator)

        # Field name with badge
        name_layout = QHBoxLayout()
        name_layout.setSpacing(4)

        self.name_label = QLabel(self.field_label)
        self.name_label.setStyleSheet(f"QLabel {{ color: {colors.TEXT_PRIMARY}; background: transparent; font-size: 10pt; font-weight: bold; }}")
        name_layout.addWidget(self.name_label)

        if self.required:
            self.badge = QLabel("REQ")
            self.badge.setStyleSheet(f"QLabel {{ font-size: 7pt; font-weight: bold; padding: 2px 5px; background-color: {colors.ERROR}; color: white; border-radius: 2px; }}")
            name_layout.addWidget(self.badge)
        else:
            self.badge = QLabel("OPT")
            self.badge.setStyleSheet(f"QLabel {{ font-size: 7pt; font-weight: bold; padding: 2px 5px; background-color: {colors.TEXT_DISABLED}; color: white; border-radius: 2px; }}")
            name_layout.addWidget(self.badge)

        name_layout.addStretch()
        layout.addLayout(name_layout, 1)

        # Combo box
        self.combo = QComboBox()
        self.combo.setMinimumWidth(160)
        self.combo.setFixedHeight(22)
        self.combo.addItems(['— Select Column —'] + columns)
        self.combo.setStyleSheet(self._get_combo_stylesheet())

        if auto_match:
            try:
                self.combo.setCurrentText(auto_match)
            except:
                pass

        layout.addWidget(self.combo)

        self.combo.currentTextChanged.connect(self._update_status)
        self._update_status()
    
    def _update_status(self):
        """Update status indicator color based on selection."""
        colors = get_theme_colors()
        selected = self.combo.currentText()
        if selected == '— Select Column —':
            color = colors.ERROR if self.required else colors.TEXT_DISABLED
        else:
            color = colors.SUCCESS
        self.status_indicator.setStyleSheet(f"border-radius: 4px; background-color: {color};")

    def refresh_theme(self):
        """Refresh all styles when theme changes."""
        colors = get_theme_colors()
        self.setStyleSheet(self._get_row_stylesheet())
        self.combo.setStyleSheet(self._get_combo_stylesheet())
        self.name_label.setStyleSheet(f"QLabel {{ color: {colors.TEXT_PRIMARY}; background: transparent; font-size: 10pt; font-weight: bold; }}")

        if self.required:
            self.badge.setStyleSheet(f"QLabel {{ font-size: 7pt; font-weight: bold; padding: 2px 5px; background-color: {colors.ERROR}; color: white; border-radius: 2px; }}")
        else:
            self.badge.setStyleSheet(f"QLabel {{ font-size: 7pt; font-weight: bold; padding: 2px 5px; background-color: {colors.TEXT_DISABLED}; color: white; border-radius: 2px; }}")

        self._update_status()
    
    def get_selected(self) -> Optional[str]:
        selected = self.combo.currentText()
        return None if selected == '— Select Column —' else selected
    
    def set_column(self, column: str):
        self.combo.setCurrentText(column)


class PropertyCard(QFrame):
    """Clean card for selecting a property column."""

    toggled = pyqtSignal(str, bool)

    def __init__(self, column_name: str, series: pd.Series, parent=None):
        super().__init__(parent)
        self.column_name = column_name
        self._is_selected = True
        self.count = len(series.dropna())
        self._setup_ui()
        self._apply_style()

    def _setup_ui(self):
        colors = get_theme_colors()
        self.setCursor(Qt.CursorShape.PointingHandCursor)
        self.setFixedHeight(32)
        self.setObjectName("PropertyCard")

        layout = QHBoxLayout(self)
        layout.setContentsMargins(8, 4, 8, 4)
        layout.setSpacing(8)

        # Selection indicator
        self.indicator = QFrame()
        self.indicator.setFixedSize(12, 12)
        layout.addWidget(self.indicator)

        # Column info
        info_layout = QVBoxLayout()
        info_layout.setSpacing(0)

        self.name_label = QLabel(self.column_name)
        info_layout.addWidget(self.name_label)

        self.type_label = QLabel(f"{self.count:,} values")
        self.type_label.setStyleSheet(f"font-size: 7pt; color: {colors.TEXT_SECONDARY};")
        info_layout.addWidget(self.type_label)

        layout.addLayout(info_layout, 1)

    def _apply_style(self):
        """Apply theme-aware styling based on selection state."""
        colors = get_theme_colors()
        if self._is_selected:
            # Light green background for selected state
            bg_color = "#d1fae5" if get_theme_colors() == get_theme_colors.__class__.__bases__[0] else "#e8f5e9"
            hover_color = "#a7f3d0" if get_theme_colors() == get_theme_colors.__class__.__bases__[0] else "#c8e6c9"
            text_color = "#065f46" if get_theme_colors() == get_theme_colors.__class__.__bases__[0] else "#1b5e20"

            self.setStyleSheet(f"""
                #PropertyCard {{
                    background-color: {bg_color};
                    border: 2px solid {colors.SUCCESS};
                    border-radius: 4px;
                }}
                #PropertyCard:hover {{ background-color: {hover_color}; }}
            """)
            self.indicator.setStyleSheet(f"background-color: {colors.SUCCESS}; border-radius: 6px;")
            self.name_label.setStyleSheet(f"color: {text_color}; font-size: 9pt; font-weight: 700;")
        else:
            self.setStyleSheet(f"""
                #PropertyCard {{
                    background-color: {colors.ELEVATED_BG};
                    border: 2px solid {colors.BORDER};
                    border-radius: 4px;
                }}
                #PropertyCard:hover {{ background-color: {colors.CARD_HOVER}; }}
            """)
            self.indicator.setStyleSheet(f"background-color: {colors.TEXT_DISABLED}; border-radius: 6px;")
            self.name_label.setStyleSheet(f"color: {colors.TEXT_SECONDARY}; font-size: 9pt; font-weight: 600;")

        # Update type label
        self.type_label.setStyleSheet(f"font-size: 7pt; color: {colors.TEXT_SECONDARY};")
    
    def mousePressEvent(self, event):
        self._is_selected = not self._is_selected
        self._apply_style()
        self.toggled.emit(self.column_name, self._is_selected)
        super().mousePressEvent(event)

    def setSelected(self, selected: bool):
        self._is_selected = selected
        self._apply_style()

    def isSelected(self) -> bool:
        return self._is_selected

    def refresh_theme(self):
        """Refresh styles when theme changes."""
        self._apply_style()


