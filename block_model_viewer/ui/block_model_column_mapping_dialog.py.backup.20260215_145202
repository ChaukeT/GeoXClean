        """)
        coord_layout = QVBoxLayout(self.coord_group)
        coord_layout.setContentsMargins(6, 6, 6, 6)
        coord_layout.setSpacing(4)

        self.combo_boxes = {}
        columns = self.df.columns.tolist()

        coord_fields = {
            'X': ('X Coordinate (Easting)', True),
            'Y': ('Y Coordinate (Northing)', True),
            'Z': ('Z Coordinate (Elevation)', True),
        }

        for key, (label, req) in coord_fields.items():
            match = self._auto_detect_column(key)
            row = BlockMappingRow(key, label, req, columns, match)
            coord_layout.addWidget(row)
            self.mapping_rows[key] = row
            self.combo_boxes[key] = row.combo

        scroll_layout.addWidget(self.coord_group)

        # Section 2: Block Attributes (Collapsible)
        self.attr_header = QPushButton("📐 Block Attributes (Optional) ▸")
        self.attr_header.setCheckable(True)
        self.attr_header.setCursor(Qt.CursorShape.PointingHandCursor)
        self.attr_header.setStyleSheet(f"""
            QPushButton {{
                background-color: {colors.ELEVATED_BG}; color: {colors.TEXT_PRIMARY};
                border: 1px solid {colors.BORDER}; border-radius: 4px;
                padding: 6px 10px; text-align: left; font-weight: 600; font-size: 9pt;
            }}
            QPushButton:hover {{ background-color: {colors.CARD_HOVER}; }}
            QPushButton:checked {{ border-color: {colors.SUCCESS}; }}
        """)
        scroll_layout.addWidget(self.attr_header)
        
        self.attr_widget = QWidget()
        attr_layout = QVBoxLayout(self.attr_widget)
        attr_layout.setContentsMargins(6, 4, 6, 4)
        attr_layout.setSpacing(4)
        
        attr_fields = {
            'DX': ('Block Size X', False),
            'DY': ('Block Size Y', False),
            'DZ': ('Block Size Z', False)
        }
        
        for key, (label, req) in attr_fields.items():
            match = self._auto_detect_column(key)
            row = BlockMappingRow(key, label, req, columns, match)
            attr_layout.addWidget(row)
            self.mapping_rows[key] = row
            self.combo_boxes[key] = row.combo
        
        self.attr_widget.setVisible(False)  # Collapsed by default
        scroll_layout.addWidget(self.attr_widget)

        self.attr_header.toggled.connect(lambda checked: (
            self.attr_widget.setVisible(checked),
            self.attr_header.setText("📐 Block Attributes (Optional) ▾" if checked else "📐 Block Attributes (Optional) ▸")
        ))
        
        # Section 3: Property Selection
        def get_mapped():
            return {r.get_selected() for r in self.mapping_rows.values() if r.get_selected()}
        
        mapped = get_mapped()
        excluded = {'X', 'Y', 'Z', 'DX', 'DY', 'DZ', 'XC', 'YC', 'ZC', 
                   'XINC', 'YINC', 'ZINC', 'X_CENTER', 'Y_CENTER', 'Z_CENTER',
                   'X_COORD', 'Y_COORD', 'Z_COORD', 'EASTING', 'NORTHING', 'ELEVATION'}
        
        numeric_cols = [c for c in self.df.columns 
                       if pd.api.types.is_numeric_dtype(self.df[c])
                       and c not in mapped
                       and c.upper() not in excluded]
        
        if numeric_cols:
            self.prop_group = QGroupBox("📊 Select Property Columns")
            self.prop_group.setStyleSheet(f"""
                QGroupBox {{
                    color: {colors.TEXT_PRIMARY}; font-weight: 600; font-size: 10pt;
                    background-color: {colors.ELEVATED_BG};
                    border: 1px solid {colors.BORDER}; border-radius: 4px;
                    margin-top: 6px; padding-top: 10px;
                }}
                QGroupBox::title {{ subcontrol-origin: margin; left: 8px; padding: 2px 6px; }}
            """)
            prop_layout = QVBoxLayout(self.prop_group)
            prop_layout.setSpacing(4)
            prop_layout.setContentsMargins(6, 6, 6, 6)

            header_layout = QHBoxLayout()
            self.info_label_prop = QLabel("Click to toggle")
            self.info_label_prop.setStyleSheet(f"color: {colors.TEXT_SECONDARY}; font-size: 8pt;")
            header_layout.addWidget(self.info_label_prop, 1)

            self.count_label = QLabel(f"{len(numeric_cols)}/{len(numeric_cols)}")
            # Initial styling (will be set by _update_count after cards are created)
            header_layout.addWidget(self.count_label)
            prop_layout.addLayout(header_layout)
            
            prop_scroll = QScrollArea()
            prop_scroll.setWidgetResizable(True)
            prop_scroll.setMinimumHeight(80)
            prop_scroll.setMaximumHeight(120)
            prop_scroll.setHorizontalScrollBarPolicy(Qt.ScrollBarPolicy.ScrollBarAlwaysOff)
            prop_scroll.setStyleSheet("QScrollArea { background: transparent; border: none; }")
            
            cards_widget = QWidget()
            cards_layout = QVBoxLayout(cards_widget)
            cards_layout.setSpacing(4)
            cards_layout.setContentsMargins(0, 0, 4, 0)
            
            self.property_cards = {}
            for col in sorted(numeric_cols):
                card = PropertyCard(col, self.df[col])
                card.toggled.connect(self._on_property_toggled)
                cards_layout.addWidget(card)
                self.property_cards[col] = card
                self.selected_property_columns.add(col)
            
            cards_layout.addStretch()
            prop_scroll.setWidget(cards_widget)
            prop_layout.addWidget(prop_scroll)
            
            btn_layout = QHBoxLayout()
            btn_layout.setSpacing(6)

            self.sel_all = QPushButton("Select All")
            self.sel_all.setCursor(Qt.CursorShape.PointingHandCursor)
            self.sel_all.setStyleSheet(f"""
                QPushButton {{
                    background-color: {colors.CARD_HOVER}; color: {colors.TEXT_PRIMARY};
                    border: 1px solid {colors.BORDER}; border-radius: 4px;
                    padding: 4px 10px; font-weight: 600; font-size: 8pt;
                }}
                QPushButton:hover {{ background-color: {colors.BORDER_LIGHT}; }}
            """)
            self.sel_all.clicked.connect(self._select_all_properties)

            self.desel_all = QPushButton("Deselect All")
            self.desel_all.setCursor(Qt.CursorShape.PointingHandCursor)
            self.desel_all.setStyleSheet(f"""
                QPushButton {{
                    background-color: {colors.CARD_HOVER}; color: {colors.TEXT_PRIMARY};
                    border: 1px solid {colors.BORDER}; border-radius: 4px;
                    padding: 4px 10px; font-weight: 600; font-size: 8pt;
                }}
                QPushButton:hover {{ background-color: {colors.BORDER_LIGHT}; }}
            """)
            self.desel_all.clicked.connect(self._deselect_all_properties)

            btn_layout.addWidget(self.sel_all)
            btn_layout.addWidget(self.desel_all)
            btn_layout.addStretch()
            prop_layout.addLayout(btn_layout)

            scroll_layout.addWidget(self.prop_group)
        else:
            # No property group created
            self.prop_group = None
            self.count_label = None
        
        scroll_layout.addStretch()
        scroll.setWidget(scroll_content)
        layout.addWidget(scroll, 1)  # Give scroll area stretch priority
        
        # Footer (Fixed)
        self.footer = QFrame()
        self.footer.setStyleSheet(f"background-color: {colors.ELEVATED_BG}; border-top: 1px solid {colors.BORDER};")
        footer_layout = QHBoxLayout(self.footer)
        footer_layout.setContentsMargins(0, 8, 0, 0)
        footer_layout.setSpacing(8)

        self.status_label = QLabel("")
        self.status_label.setStyleSheet(f"color: {colors.TEXT_SECONDARY}; font-size: 8pt;")
        footer_layout.addWidget(self.status_label, 1)

        self.cancel_btn = QPushButton("Cancel")
        self.cancel_btn.setCursor(Qt.CursorShape.PointingHandCursor)
        self.cancel_btn.setMinimumWidth(80)
        self.cancel_btn.setStyleSheet(f"""
            QPushButton {{
                background-color: {colors.BORDER_LIGHT}; color: {colors.TEXT_PRIMARY};
                border: none; border-radius: 5px;
                padding: 8px 16px; font-size: 9pt; font-weight: 600;
            }}
            QPushButton:hover {{ background-color: {colors.CARD_HOVER}; }}
        """)
        self.cancel_btn.clicked.connect(self.reject)
        footer_layout.addWidget(self.cancel_btn)

        self.accept_btn = QPushButton("✓ Apply Mapping")
        self.accept_btn.setCursor(Qt.CursorShape.PointingHandCursor)
        self.accept_btn.setDefault(True)
        self.accept_btn.setMinimumWidth(120)
        self.accept_btn.setStyleSheet(f"""
            QPushButton {{
                background-color: {colors.SUCCESS}; color: white;
                border: none; border-radius: 5px;
                padding: 8px 16px; font-size: 9pt; font-weight: 700;
            }}
            QPushButton:hover {{ background-color: {colors.ACCENT_SECONDARY}; }}
        """)
        self.accept_btn.clicked.connect(self._validate_and_accept)
        footer_layout.addWidget(self.accept_btn)

        layout.addWidget(self.footer)
    
    def _auto_detect_column(self, key: str) -> Optional[str]:
        cols_upper = [c.upper() for c in self.df.columns]
        patterns = {
            'X': ['X', 'X_CENTER', 'X_CENTRE', 'XC', 'XPOS', 'X_COORD', 'EASTING'],
            'Y': ['Y', 'Y_CENTER', 'Y_CENTRE', 'YC', 'YPOS', 'Y_COORD', 'NORTHING'],
            'Z': ['Z', 'Z_CENTER', 'Z_CENTRE', 'ZC', 'ZPOS', 'Z_COORD', 'ELEVATION', 'RL'],
            'DX': ['DX', 'DX_SIZE', 'SIZE_X', 'WIDTH', 'XSIZE', 'XINC'],
            'DY': ['DY', 'DY_SIZE', 'SIZE_Y', 'LENGTH', 'YSIZE', 'YINC'],
            'DZ': ['DZ', 'DZ_SIZE', 'SIZE_Z', 'HEIGHT', 'ZSIZE', 'ZINC']
        }
        if key in patterns:
            for pat in patterns[key]:
                if pat in cols_upper:
                    return self.df.columns[cols_upper.index(pat)]
        return None
    
    def _on_property_toggled(self, col: str, selected: bool):
        if selected:
            self.selected_property_columns.add(col)
        else:
            self.selected_property_columns.discard(col)
        self._update_count()
    
    def _update_count(self):
        """Update property count label with theme-aware styling."""
        if not hasattr(self, 'count_label') or not hasattr(self, 'property_cards') or self.count_label is None:
            return

        colors = get_theme_colors()
        total = len(self.property_cards)
        sel = len(self.selected_property_columns)
        self.count_label.setText(f"{sel}/{total}")

        if sel == 0:
            # Error state - no properties selected
            self.count_label.setStyleSheet(f"""
                color: {colors.ERROR}; background: rgba(244,67,54,0.15);
                padding: 3px 8px; border-radius: 8px; border: 1px solid {colors.ERROR};
                font-size: 8pt; font-weight: 700;
            """)
        elif sel == total:
            # Success state - all properties selected
            self.count_label.setStyleSheet(f"""
                color: {colors.SUCCESS}; background: rgba(76,175,80,0.15);
                padding: 3px 8px; border-radius: 8px; border: 1px solid {colors.SUCCESS};
                font-size: 8pt; font-weight: 700;
            """)
        else:
            # Info state - partial selection
            self.count_label.setStyleSheet(f"""
                color: {colors.INFO}; background: rgba(33,150,243,0.15);
                padding: 3px 8px; border-radius: 8px; border: 1px solid {colors.INFO};
                font-size: 8pt; font-weight: 700;
            """)
    
    def _select_all_properties(self):
        if hasattr(self, 'property_cards'):
            for col, card in self.property_cards.items():
                card.setSelected(True)
                self.selected_property_columns.add(col)
            self._update_count()
    
    def _deselect_all_properties(self):
        if hasattr(self, 'property_cards'):
            for card in self.property_cards.values():
                card.setSelected(False)
            self.selected_property_columns.clear()
            self._update_count()
    
    def _auto_detect_all(self):
        """Auto-detect all column mappings."""
        colors = get_theme_colors()
        count = 0
        for key, row in self.mapping_rows.items():
            match = self._auto_detect_column(key)
            if match:
                row.set_column(match)
                count += 1
        self.status_label.setText(f"✓ Auto-detected {count}/{len(self.mapping_rows)} columns")
        self.status_label.setStyleSheet(f"color: {colors.SUCCESS}; font-size: 9pt; font-weight: 600;")
    
    def _validate_and_accept(self):
        """Validate mappings and accept dialog."""
        colors = get_theme_colors()
        self.column_mapping = {}
        for key, row in self.mapping_rows.items():
            sel = row.get_selected()
            if sel:
                self.column_mapping[key] = sel

        if hasattr(self, 'property_cards'):
            self.selected_property_columns.clear()
            for col, card in self.property_cards.items():
                if card.isSelected():
                    self.selected_property_columns.add(col)

        req = ['X', 'Y', 'Z']
        missing = [f for f in req if f not in self.column_mapping]
        if missing:
            self.status_label.setText(f"✗ Missing required: {', '.join(missing)}")
            self.status_label.setStyleSheet(f"color: {colors.ERROR}; font-size: 9pt; font-weight: 700;")
            return

        mapped = list(self.column_mapping.values())
        dups = [c for c in mapped if mapped.count(c) > 1]
        if dups:
            self.status_label.setText(f"✗ Duplicate mappings: {', '.join(set(dups))}")
            self.status_label.setStyleSheet(f"color: {colors.ERROR}; font-size: 9pt; font-weight: 700;")
            return

        self.accept()
    
    def get_mapping(self) -> Dict[str, str]:
        return self.column_mapping

    def get_selected_properties(self) -> Set[str]:
        return self.selected_property_columns

