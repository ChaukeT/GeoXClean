        # Update group boxes
        for group in [self.coord_group, self.prop_group if hasattr(self, 'prop_group') and self.prop_group else None]:
            if group:
                group.setStyleSheet(f"""
                    QGroupBox {{
                        color: {colors.TEXT_PRIMARY}; font-weight: 600; font-size: 10pt;
