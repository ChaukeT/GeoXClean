    def _get_action_info(self, name: str) -> Tuple[str, str]:
        """Get shortcut and category for an action."""
        action = self._action_map.get(name)
        shortcut = ""
        category = ""

        if action:
            shortcut_seq = action.shortcut()
            if shortcut_seq and not shortcut_seq.isEmpty():
                shortcut = shortcut_seq.toString()

            # Try to determine category from parent menu
            parent = action.parent()
            if parent:
                parent_name = parent.objectName() if hasattr(parent, 'objectName') else ""
                if "file" in parent_name.lower():
                    category = "File"
                elif "edit" in parent_name.lower():
                    category = "Edit"
                elif "view" in parent_name.lower():
                    category = "View"
                elif "tool" in parent_name.lower():
                    category = "Tools"
                elif "analysis" in parent_name.lower():
                    category = "Analysis"
                elif "help" in parent_name.lower():
                    category = "Help"

        # Infer category from action name if not determined
        if not category:
            name_lower = name.lower()
            if any(w in name_lower for w in ["open", "save", "export", "import", "new", "close"]):
                category = "File"
            elif any(w in name_lower for w in ["copy", "paste", "cut", "undo", "redo"]):
                category = "Edit"
            elif any(w in name_lower for w in ["view", "show", "hide", "zoom", "pan"]):
                category = "View"
            elif any(w in name_lower for w in ["tool", "setting", "preference", "config"]):
                category = "Tools"
            elif any(w in name_lower for w in ["analysis", "calculate", "compute", "run"]):
                category = "Analysis"
            elif any(w in name_lower for w in ["help", "about", "doc", "guide"]):
                category = "Help"
            elif any(w in name_lower for w in ["search", "find"]):
                category = "Search"
            else:
                category = "Tools"

        return shortcut, category

    def _on_search_changed(self, text: str):
        """Filter the list based on the search text with fuzzy matching."""
        self.delegate.set_search_text(text)

        if not text:
            self._populate_list(self.items)
            return

        # Fuzzy search: match items where all search terms appear
        search_terms = text.lower().split()
        scored_items = []

        for item in self.items:
            name_lower = item[0].lower()
            desc_lower = item[1].lower()
            combined = name_lower + " " + desc_lower

            # Check if all terms match
            if all(term in combined for term in search_terms):
                # Score: prioritize name matches over description matches
                score = 0
                for term in search_terms:
                    if term in name_lower:
                        # Bonus for start match
                        if name_lower.startswith(term):
                            score += 100
                        else:
                            score += 50
                    elif term in desc_lower:
                        score += 10

                scored_items.append((score, item))

        # Sort by score (descending) then alphabetically
        scored_items.sort(key=lambda x: (-x[0], x[1][0].lower()))
        filtered_items = [item for _, item in scored_items]

        self._populate_list(filtered_items)

        # Select first item after filtering
        if self.results_list.count() > 0:
            self.results_list.setCurrentRow(0)

    def _populate_list(self, items: List[Tuple[str, str]]):
        """Populate the list widget with items."""
        self.results_list.clear()

        for name, description in items:
            item = QListWidgetItem()
            item.setData(Qt.ItemDataRole.DisplayRole, name)
            item.setData(Qt.ItemDataRole.ToolTipRole, description)
            item.setData(Qt.ItemDataRole.UserRole, name)  # For selection

            # Get shortcut and category
            shortcut, category = self._get_action_info(name)
            item.setData(Qt.ItemDataRole.UserRole + 1, shortcut)
            item.setData(Qt.ItemDataRole.UserRole + 2, category)

            item.setSizeHint(QSize(0, 52))
            self.results_list.addItem(item)

        # Update result count
        self.result_count.setText(f"{len(items)} results")

    def _on_item_activated(self, item: QListWidgetItem):
        """Handle item activation (e.g., double-click or Enter)."""
        # Guard against multiple triggers
        if self._selection_handled:
            return
        self._selection_handled = True

        selected_item_name = item.data(Qt.ItemDataRole.UserRole)
        if selected_item_name:
            # Store the selected name - it will be retrieved after exec() returns
            self._selected_name = selected_item_name
            self.accept()

    def get_selected_item(self) -> Optional[str]:
        """Return the selected item name, or None if nothing was selected."""
        return getattr(self, '_selected_name', None)

    def keyPressEvent(self, event):
        """Handle key presses for navigation."""
        key = event.key()

        if key == Qt.Key.Key_Escape:
            self.reject()
        elif key == Qt.Key.Key_Return or key == Qt.Key.Key_Enter:
            current = self.results_list.currentItem()
            if current:
                self._on_item_activated(current)
        elif key == Qt.Key.Key_Up:
            current_row = self.results_list.currentRow()
            if current_row > 0:
                self.results_list.setCurrentRow(current_row - 1)
                self.results_list.scrollToItem(self.results_list.currentItem())
        elif key == Qt.Key.Key_Down:
            current_row = self.results_list.currentRow()
            if current_row < self.results_list.count() - 1:
                self.results_list.setCurrentRow(current_row + 1)
                self.results_list.scrollToItem(self.results_list.currentItem())
        elif key == Qt.Key.Key_Tab:
            # Tab cycles through results
            if self.results_list.count() > 0:
                current_row = self.results_list.currentRow()
                next_row = (current_row + 1) % self.results_list.count()
                self.results_list.setCurrentRow(next_row)
        else:
            # Forward other keys to search input
            if not self.search_input.hasFocus():
                self.search_input.setFocus()
            super().keyPressEvent(event)

    def showEvent(self, event):
        """Handle dialog show event."""
        super().showEvent(event)
        # Focus on search input when shown
        self.search_input.setFocus()
        self.search_input.selectAll()

        # Center on parent
        if self.parent():
            parent_geo = self.parent().geometry()
            self.move(
                parent_geo.x() + (parent_geo.width() - self.width()) // 2,
                parent_geo.y() + 100  # Slightly above center for command palette feel
            )
