    def _on_cancel_compositing(self):
        """Handle cancel request from the modern status bar."""
        self._cancel_requested = True
        self.modern_status_bar.update_status("Cancellation requested", StatusLevel.WARNING)
        self.status_label.setText("Compositing cancelled by user")
        logger.info("User requested compositing cancellation")

    def on_run_clicked(self):
        # Reset cancellation flag
        self._cancel_requested = False

        # Start modern status bar progress
        self.modern_status_bar.start_process(cancellable=True)
        self.modern_status_bar.update_status("Starting compositing process", StatusLevel.INFO)
        
        self.status_label.setText("Checking validation status...")
        QApplication.processEvents()
        
        # Step 1: Validation Check
        self.modern_status_bar.advance_step()
        self.modern_status_bar.update_status("Checking data validation status")
        QApplication.processEvents()
        
        # VALIDATION GATE: Check drillhole validation state before compositing
        validation_blocked, validation_msg = self._check_validation_gate()
        if validation_blocked:
            self.modern_status_bar.set_step_error("Validation check failed")
            return

        self.status_label.setText("Running compositing...")
        QApplication.processEvents()

        tab = self.tabs.currentWidget()
        if not isinstance(tab, BaseCompositingTab):
            return

        if not self.compositing_engine:
            # Demo mode
            self._generate_dummy_results()
            self.modern_status_bar.finish_process(success=True, message="Compositing complete (DEMO MODE)")
            self.status_label.setText("Compositing complete (DEMO MODE).")
            return

        # Step 2: Data Preparation
        self.modern_status_bar.advance_step()
        self.modern_status_bar.update_status("Preparing intervals for compositing")
        QApplication.processEvents()

        # Production Logic
        ui_engine = tab.get_ui_engine()
        state = tab.get_state()

        if not ui_engine or not state:
            QMessageBox.warning(self, "Error", "UI engine or state not available.")
            self.modern_status_bar.set_step_error("Missing backend components")
            self.status_label.setText("Error: Missing backend.")
            return

        # Validate UI parameters
        result = ui_engine.validate(state)
        if not tab.apply_validation_result(result):
            self.modern_status_bar.set_step_error("Configuration validation failed")
            self.status_label.setText("Validation failed.")
            return

        # Step 3: Composite Calculation
        self.modern_status_bar.advance_step()
        self.modern_status_bar.update_status("Computing composite intervals")
        QApplication.processEvents()

        # Run with progress reporting
        try:
            cfg = ui_engine.to_config(state)
            
            # Progress callback to update both status bars
            def progress_callback(percent: int, message: str):
                # Check for cancellation request
                if self._cancel_requested:
                    raise InterruptedError("Compositing cancelled by user")

                self.status_label.setText(f"[{percent}%] {message}")
                # Update modern status bar step progress
                if percent > 0:
                    self.modern_status_bar.advance_step(percent / 100.0)
                QApplication.processEvents()  # Keep UI responsive
            
            self.status_label.setText("Starting compositing...")
            QApplication.processEvents()
            
            composites = self.compositing_engine.composite(
                self.intervals, 
                cfg, 
                progress_callback=progress_callback
            )
            
            # Step 4: Grade Calculation
            self.modern_status_bar.advance_step()
            self.modern_status_bar.update_status("Calculating weighted averages")
            QApplication.processEvents()
            
            df = self._composites_to_dataframe(composites)
            
            # Step 5: Quality Check
            self.modern_status_bar.advance_step()
            self.modern_status_bar.update_status("Validating composite results")
            QApplication.processEvents()
            
            self.results_widget.update_results(df)
            
            # Store results for later registry application
            self._last_composites_df = df
            self._last_composites = composites
            self._last_config = cfg  # Store config for audit trail
            
            # Enable the Apply to Registry button
            self.btn_apply_registry.setEnabled(True)
            
            # Log compositing run to audit trail
            self._log_compositing_run(cfg, len(df), validation_msg)
            
            # Step 6: Output Generation - Final step
            self.modern_status_bar.advance_step()
            success_msg = f"Done. Generated {len(df)} composites. Click 'Apply to Registry' to use in Variograms/Kriging."
            self.modern_status_bar.finish_process(success=True, message=success_msg)
            self.modern_status_bar.update_status("Compositing completed successfully", StatusLevel.SUCCESS)
            self.status_label.setText(success_msg)
        
        # C-03, C-04, C-05 FIX: Catch specific ValueError exceptions with user-friendly messages
        except ValueError as e:
            error_msg = str(e)
            logger.error(f"Compositing configuration error: {e}", exc_info=True)
            
            # Provide user-friendly messages for common errors
            if "density" in error_msg.lower():
                user_msg = (
                    "Missing Density Data\n\n"
                    f"The selected compositing method requires density values, but some intervals "
                    f"are missing density data.\n\n"
                    f"Solutions:\n"
                    f"• Switch to 'Length' weighting mode\n"
                    f"• Ensure all intervals have density values in your data\n"
                    f"• Use a different compositing method\n\n"
                    f"Technical details: {error_msg}"
                )
            elif "true_thickness" in error_msg.lower():
                user_msg = (
                    "Missing True Thickness Data\n\n"
                    f"True thickness compositing requires true_thickness values on all intervals.\n\n"
                    f"Solutions:\n"
                    f"• Calculate true thickness from survey data first\n"
                    f"• Use 'Fixed Length' compositing instead\n\n"
                    f"Technical details: {error_msg}"
                )
            elif "target_mass" in error_msg.lower() or "equal_mass" in error_msg.lower():
                user_msg = (
                    "Invalid Equal Mass Configuration\n\n"
                    f"Equal mass compositing requires a valid target mass and density data.\n\n"
                    f"Solutions:\n"
                    f"• Set a target mass value > 0\n"
                    f"• Ensure weighting mode is MASS or DENSITY\n"
                    f"• Ensure all intervals have density values\n\n"
                    f"Technical details: {error_msg}"
                )
            elif "composite_length" in error_msg.lower():
                user_msg = (
                    "Invalid Composite Length\n\n"
                    f"Composite length must be greater than 0.\n\n"
                    f"Solution: Set a valid composite length (e.g., 1.0, 2.0, 5.0 metres)\n\n"
                    f"Technical details: {error_msg}"
                )
            elif "cutoff" in error_msg.lower():
                user_msg = (
                    "Missing Cutoff Configuration\n\n"
                    f"Economic/Indicator compositing requires cutoff field and grade.\n\n"
                    f"Solutions:\n"
                    f"• Select a grade field (e.g., Fe, Au, Cu)\n"
                    f"• Set a cutoff grade value\n\n"
                    f"Technical details: {error_msg}"
                )
            else:
                user_msg = (
                    f"Compositing Configuration Error\n\n"
                    f"{error_msg}\n\n"
                    f"Please check your compositing parameters and try again."
                )
            
            QMessageBox.warning(self, "Configuration Error", user_msg)
            self.modern_status_bar.update_status("Configuration error", StatusLevel.ERROR)
            self.modern_status_bar.set_step_error(error_msg)
            self.status_label.setText("Configuration error - see message.")

        except InterruptedError:
            # User cancelled the operation
            logger.info("Compositing cancelled by user")
            self.modern_status_bar.finish_process(success=False, message="Compositing cancelled")
            self.modern_status_bar.update_status("Cancelled by user", StatusLevel.WARNING)
            self.status_label.setText("Compositing cancelled by user.")

        except Exception as e:
            logger.error(f"Compositing error: {e}", exc_info=True)
            QMessageBox.critical(self, "Execution Error", str(e))
            self.modern_status_bar.update_status("Execution error occurred", StatusLevel.ERROR)
            self.modern_status_bar.set_step_error(str(e))
            self.status_label.setText("Error occurred.")

    def refresh_intervals(self, new_intervals):
        """Refresh the intervals used for compositing.

        This should be called when drillhole data changes to ensure
        compositing uses the latest data instead of stale cached intervals.

        M-04 FIX: Also clears stale composite results to prevent confusion.
        """
        if new_intervals is not None:
            self.intervals = new_intervals
            logger.info(f"Refreshed compositing intervals: {len(self.intervals)} intervals")

            # Check for excluded rows and show info
            registry = self.get_registry()
            excluded_info = ""
            if registry:
                state = registry.get_drillholes_validation_state()
                if state:
                    excluded_rows = state.get("excluded_rows", {})
                    excluded_count = sum(len(rows) for rows in excluded_rows.values())
                    if excluded_count > 0:
                        excluded_info = f" ({excluded_count} rows with errors excluded)"

            self.status_label.setText(f"Data refreshed: {len(self.intervals)} intervals available{excluded_info}")

            # M-04 FIX: Clear stale composite results when data changes
            self._clear_stale_composites()

            # Update validation status indicator
            self._update_validation_status_indicator()
        else:
            logger.warning("Attempted to refresh with None intervals")
            self.status_label.setText("Warning: No intervals available")
    
    def _check_validation_gate(self) -> tuple:
        """
        Check drillhole validation state before allowing compositing.
        
        AUDIT: This is a critical gate to ensure JORC/SAMREC compliance.
        Compositing should NOT run on unvalidated or failed data by default.
        
        Returns:
            Tuple of (blocked: bool, message: str)
            blocked=True means compositing should NOT proceed
        """
        override_checked = self.cb_validation_override.isChecked()
        
        # Get registry
        registry = self.get_registry()
        if registry is None:
            # No registry available - allow compositing (backward compatibility)
            logger.warning("No registry available - skipping validation gate")
            return (False, "")
        
        # Get validation state
        validation_state = registry.get_drillholes_validation_state()
        
        if validation_state is None:
            # Never validated
            self._update_validation_status_indicator("NOT_RUN")
            
            if override_checked:
                logger.warning("Compositing on unvalidated data (override enabled)")
                return (False, "override_not_run")
            
            QMessageBox.warning(
                self,
                "Validation Required",
                "Drillhole data has NOT been validated.\n\n"
                "Please open the QC Window and run validation before compositing.\n\n"
                "If you must proceed without validation, check the 'Override' checkbox.\n"
                "WARNING: This may produce invalid results and is not JORC/SAMREC compliant."
            )
            self.status_label.setText("Blocked: Validation required")
            self.cb_validation_override.setVisible(True)
            return (True, "Validation not run")
        
        status = validation_state.get("status", "NOT_RUN")
        fatal_count = validation_state.get("fatal_count", 0)
        warn_count = validation_state.get("warn_count", 0)
        
        self._update_validation_status_indicator(status)
        
        if status == "FAIL":
            if override_checked:
                # Log override with audit trail
                logger.warning(
                    f"Compositing on FAILED validation (override enabled): "
                    f"{fatal_count} errors, {warn_count} warnings"
                )
                self._log_validation_override(validation_state, "FAIL")
                return (False, "override_fail")
            
            QMessageBox.warning(
                self,
                "Validation Failed",
                f"Drillhole validation FAILED with {fatal_count} error(s).\n\n"
                "Please open the QC Window and fix the errors before compositing.\n\n"
                "If you must proceed with invalid data, check the 'Override' checkbox.\n"
                "WARNING: This may produce invalid results and is not JORC/SAMREC compliant."
            )
            self.status_label.setText(f"Blocked: {fatal_count} validation errors")
            self.cb_validation_override.setVisible(True)
            return (True, f"Validation failed: {fatal_count} errors")
        
        if status == "WARN":
            # Warnings are allowed but logged
            logger.info(
                f"Compositing with validation warnings: {warn_count} warning(s)"
            )
            return (False, "warn")
        
        # PASS - all good
        return (False, "pass")
    
    def _update_validation_status_indicator(self, status: Optional[str] = None):
        """Update the validation status indicator in the action bar.

        Also shows info about excluded rows (rows with ERROR violations that are
        filtered out of compositing even if 'ignored' in QC UI).
        """
        excluded_count = 0
        if status is None:
            # Fetch from registry
            registry = self.get_registry()
            if registry:
                state = registry.get_drillholes_validation_state()
                status = state.get("status", "NOT_RUN") if state else "NOT_RUN"
                # Count excluded rows
                if state:
                    excluded_rows = state.get("excluded_rows", {})
                    excluded_count = sum(len(rows) for rows in excluded_rows.values())
            else:
                status = "NOT_RUN"

        # Build status text with excluded rows info
        excluded_suffix = f" ({excluded_count} rows excluded)" if excluded_count > 0 else ""

        if status == "PASS":
            self.validation_status_label.setText(f"✅ Validation: PASS{excluded_suffix}")
            self.validation_status_label.setStyleSheet("font-size: 9pt; color: #4CAF50; font-weight: bold;")
            self.cb_validation_override.setVisible(False)
        elif status == "WARN":
            self.validation_status_label.setText(f"⚠️ Validation: WARN{excluded_suffix}")
            self.validation_status_label.setStyleSheet("font-size: 9pt; color: #e67e22; font-weight: bold;")
            self.cb_validation_override.setVisible(False)
        elif status == "FAIL":
            self.validation_status_label.setText(f"❌ Validation: FAIL{excluded_suffix}")
            self.validation_status_label.setStyleSheet("font-size: 9pt; color: #e74c3c; font-weight: bold;")
            self.cb_validation_override.setVisible(True)
        else:  # NOT_RUN
            self.validation_status_label.setText("⚪ Validation: Not Run")
            self.validation_status_label.setStyleSheet("font-size: 9pt; color: #888;")
            self.cb_validation_override.setVisible(True)
    
    def _log_validation_override(self, validation_state: dict, override_status: str):
        """Log validation override to audit trail for JORC/SAMREC compliance."""
        try:
            from ..core.audit_manager import AuditManager
            audit = AuditManager()
            audit.log_event(
                module="compositing",
                action="validation_override",
                parameters={
                    "override_status": override_status,
                    "validation_timestamp": validation_state.get("timestamp", ""),
                    "validation_config_hash": validation_state.get("config_hash", ""),
                },
                result_summary={
                    "fatal_count": validation_state.get("fatal_count", 0),
                    "warn_count": validation_state.get("warn_count", 0),
                    "reason": "User override of validation gate",
                }
            )
            logger.info("Validation override logged to audit trail")
        except Exception as e:
            logger.debug(f"Audit logging failed (non-critical): {e}")
    
    def _log_compositing_run(self, cfg, composite_count: int, validation_status: str):
        """Log compositing run to audit trail for JORC/SAMREC compliance."""
        try:
            from ..core.audit_manager import AuditManager
            audit = AuditManager()
            
            # Compute config hash for reproducibility
            config_dict = {
                "method": cfg.method.value if hasattr(cfg.method, 'value') else str(cfg.method),
                "composite_length": cfg.composite_length,
                "weighting_mode": cfg.weighting_mode.value if hasattr(cfg.weighting_mode, 'value') else str(cfg.weighting_mode),
                "partial_strategy": cfg.partial_strategy.value if hasattr(cfg.partial_strategy, 'value') else str(cfg.partial_strategy),
                "treat_null_as_zero": cfg.treat_null_as_zero,
                "exclude_qaqc": cfg.exclude_qaqc,
            }
            config_hash = hashlib.sha256(
                json.dumps(config_dict, sort_keys=True, default=str).encode()
            ).hexdigest()[:16]
            
            audit.log_event(
                module="compositing",
                action="compositing_run",
                parameters=config_dict,
                input_data_hash=config_hash,
                result_summary={
                    "composite_count": composite_count,
                    "input_interval_count": len(self.intervals) if self.intervals else 0,
                    "validation_status": validation_status,
                    "config_hash": config_hash,
                }
            )
            logger.info(f"Compositing run logged to audit trail: {composite_count} composites, config_hash={config_hash}")
        except Exception as e:
            logger.debug(f"Audit logging failed (non-critical): {e}")
    
    def _clear_stale_composites(self):
        """Clear stale composite results from previous runs.
        
        M-04 FIX: Ensures old composites don't persist when data changes.
        """
        if self._last_composites_df is not None or self._last_composites is not None:
            logger.info("Clearing stale composite results due to data refresh")
            self._last_composites_df = None
            self._last_composites = None
            self.btn_apply_registry.setEnabled(False)
            # Clear results display
            self.results_widget.update_results(pd.DataFrame())

