    def _composites_to_dataframe(self, composites) -> pd.DataFrame:
        # Map composite objects to DF
        rows = []
        for c in composites:
            row = {
                "HoleID": c.hole_id,
                "From": c.from_depth,
                "To": c.to_depth,
            }
            row.update(c.grades)
            # Add metadata fields as separate columns
            for key, value in c.metadata.items():
                if key not in row:
                    row[key] = value
            rows.append(row)
        
        df = pd.DataFrame(rows)
        
        # Add X, Y, Z coordinates if not present
        # Get drillhole data from registry to compute coordinates
        if 'X' not in df.columns or 'Y' not in df.columns or 'Z' not in df.columns:
            try:
                from ..utils.coordinate_utils import ensure_xyz_columns
                
                registry = self.get_registry()
                if registry:
                    drillhole_data = registry.get_drillhole_data()
                    if drillhole_data and isinstance(drillhole_data, dict):
                        # Get assays with coordinates (they should have X, Y, Z from desurveying)
                        assays = drillhole_data.get('assays')
                        if assays is not None and not assays.empty:
                            # Check if assays have coordinates
                            has_coords = any(col.upper() in ['X', 'Y', 'Z'] for col in assays.columns)
                            
                            coords_assigned = False
                            if has_coords:
                                # Merge coordinates from assays based on HoleID and depth
                                # For each composite, find the closest assay point
                                df['X'] = 0.0
                                df['Y'] = 0.0
                                df['Z'] = 0.0

                                # Standardize column names
                                hole_col = next((c for c in ['HOLEID', 'hole_id', 'HoleID'] if c in assays.columns), None)
                                from_col = next((c for c in ['FROM', 'from', 'From', 'DEPTH_FROM'] if c in assays.columns), None)
                                x_col = next((c for c in ['X', 'x'] if c in assays.columns), None)
                                y_col = next((c for c in ['Y', 'y'] if c in assays.columns), None)
                                z_col = next((c for c in ['Z', 'z'] if c in assays.columns), None)

                                if hole_col and from_col and x_col and y_col and z_col:
                                    # OPTIMIZED: Vectorized coordinate assignment
                                    # Pre-build lookup dict for O(1) access per hole
                                    from scipy.spatial import cKDTree

                                    df['mid_depth'] = (df['From'] + df['To']) / 2.0

                                    # Group assays by hole for efficient lookup
                                    for hole_id in df['HoleID'].unique():
                                        hole_mask = df['HoleID'] == hole_id
                                        hole_assays = assays[assays[hole_col] == hole_id]

                                        if not hole_assays.empty:
                                            # Build KDTree on depths for fast nearest lookup
                                            assay_depths = hole_assays[from_col].values.reshape(-1, 1)
                                            tree = cKDTree(assay_depths)

                                            comp_depths = df.loc[hole_mask, 'mid_depth'].values.reshape(-1, 1)
                                            _, nearest_idx = tree.query(comp_depths, k=1)

                                            # Get coordinates using iloc for fast indexing
                                            df.loc[hole_mask, 'X'] = hole_assays[x_col].iloc[nearest_idx].values
                                            df.loc[hole_mask, 'Y'] = hole_assays[y_col].iloc[nearest_idx].values
                                            df.loc[hole_mask, 'Z'] = hole_assays[z_col].iloc[nearest_idx].values
                                            coords_assigned = True

                                    df.drop('mid_depth', axis=1, inplace=True, errors='ignore')

                            # If no coordinates assigned from assays, try collars (simple vertical assumption)
                            if not coords_assigned:
                                collars = drillhole_data.get('collars')
                                if collars is not None and not collars.empty:
                                    df['X'] = 0.0
                                    df['Y'] = 0.0
                                    df['Z'] = 0.0
                                    
                                    collar_hole_col = next((c for c in ['HOLEID', 'hole_id', 'HoleID'] if c in collars.columns), None)
                                    x_col = next((c for c in ['X', 'x', 'EASTING', 'easting'] if c in collars.columns), None)
                                    y_col = next((c for c in ['Y', 'y', 'NORTHING', 'northing'] if c in collars.columns), None)
                                    z_col = next((c for c in ['Z', 'z', 'ELEVATION', 'elevation'] if c in collars.columns), None)
                                    
                                    if collar_hole_col and x_col and y_col and z_col:
                                        # OPTIMIZED: Vectorized collar lookup using merge
                                        df['mid_depth'] = (df['From'] + df['To']) / 2.0
                                        
                                        # Create collar lookup dict
                                        collar_dict = collars.set_index(collar_hole_col)[[x_col, y_col, z_col]].to_dict('index')
                                        
                                        # Vectorized assignment
                                        df['X'] = df['HoleID'].map(lambda h: collar_dict.get(h, {}).get(x_col, 0.0))
                                        df['Y'] = df['HoleID'].map(lambda h: collar_dict.get(h, {}).get(y_col, 0.0))
                                        collar_z = df['HoleID'].map(lambda h: collar_dict.get(h, {}).get(z_col, 0.0))
                                        df['Z'] = collar_z - df['mid_depth']  # Simple vertical assumption
                                        
                                        df.drop('mid_depth', axis=1, inplace=True, errors='ignore')
                                
                        # Ensure X, Y, Z columns are standardized
                        df = ensure_xyz_columns(df)
            except Exception as e:
                logger.warning(f"Could not add coordinates to composites: {e}")
        
        return df
    
    def get_registry(self):
        """
        Get DataRegistry instance via dependency injection.
        
        Tries to get registry from:
        1. Controller (if bound) -> controller.registry
        2. MainWindow parent -> main_window.controller.registry
        3. Falls back to singleton for backward compatibility
        
        Returns:
            DataRegistry instance
        """
        # Try controller first (preferred - dependency injection)
        if self.controller and hasattr(self.controller, 'registry'):
            return self.controller.registry
        
        # Try MainWindow parent
        parent = self.parent()
        while parent:
            if hasattr(parent, 'controller') and parent.controller:
                if hasattr(parent.controller, 'registry'):
                    return parent.controller.registry
            # Check if parent is MainWindow
            if hasattr(parent, '_registry') and parent._registry:
                return parent._registry
            parent = parent.parent()
        
        # Fallback to singleton (backward compatibility)
        from ..core.data_registry import DataRegistry
        return DataRegistry.instance()
    
    def _save_composites_to_registry(self, df: pd.DataFrame, composites):
        """Save composited results to DataRegistry via controller if available.
        
        H-03 FIX: Uses copy of existing data to avoid mutation of original dict.
        """
        try:
            # Prefer controller.save_composites() if available
            if self.controller and hasattr(self.controller, 'save_composites'):
                try:
                    self.controller.save_composites(df, composites)
                    logger.info(f"Saved {len(df)} composites via controller")
                    return
                except AttributeError:
                    # Controller doesn't have save_composites method, fall through to direct registry
                    pass
            
            # Fallback to direct registry access
            registry = self.get_registry()
            if registry is None:
                logger.warning("DataRegistry not available for saving composites")
                return
            
            # H-03 FIX: Get existing drillhole data and create a COPY to avoid mutation
            existing_data = registry.get_drillhole_data(copy_data=True)  # Request a copy
            if existing_data is None:
                existing_data = {}
            else:
                # Ensure we have a proper copy even if copy_data wasn't supported
                existing_data = dict(existing_data)
            
            # Add composited data to the copy
            existing_data['composites'] = df.copy()
            
            # Build metadata for audit trail with full lineage
            composite_method = 'unknown'
            if composites and len(composites) > 0:
                composite_method = composites[0].metadata.get('method', 'unknown')
            
            # Get validation state for lineage tracking
            validation_state = registry.get_drillholes_validation_state() or {}
            
            metadata = {
                'composite_count': len(df),
                'composite_method': composite_method,
                'source': 'CompositingWindow',
                'action': 'composites_added',
                # LINEAGE PROVENANCE - Critical for audit trail
                'parent_data_key': 'assays',  # Composites are derived from assays
                'transformation_type': 'compositing',
                'transformation_params': {
                    'method': composite_method,
                    'count': len(df),
                },
                'validation_status': validation_state.get('status', 'NOT_RUN'),
                'validation_config_hash': validation_state.get('config_hash', ''),
                'validation_timestamp': validation_state.get('timestamp', ''),
                'override_used': self.cb_validation_override.isChecked(),
            }
            
            # Register updated data (registry will store a new version)
            registry.register_drillhole_data(
                existing_data,
                source_panel="Compositing Window",
                metadata=metadata
            )
            
            logger.info(f"Saved {len(df)} composites to DataRegistry (method={composite_method})")
            
        except Exception as e:
            logger.error(f"Error saving composites to DataRegistry: {e}", exc_info=True)
            QMessageBox.warning(
                self,
                "Save Warning",
                f"Composited data was generated but could not be saved to DataRegistry:\n{e}\n\n"
                "You can still export the results manually."
            )

