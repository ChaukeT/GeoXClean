    def _sync_from_economic_tab(self):
        """Copy economic rule from Economic tab to this tab's fields."""
        if not self._parent_window:
            QMessageBox.warning(
                self,
                "Cannot Sync",
                "Parent window reference not set. Cannot sync from Economic tab."
            )
            return

        # Get economic rule from Economic tab
        economic_rule = self._parent_window.tab_economic.get_economic_rule()

        if not economic_rule:
            QMessageBox.warning(
                self,
                "No Rule Defined",
                "Economic tab does not have a valid rule defined.\n\n"
                "Please define cutoff criteria in the Economic tab first."
            )
            return

        # Copy rule to this tab's fields
        self.indicator_field.setCurrentText(economic_rule.field)
        self.cutoff_op.setCurrentText(economic_rule.operator)
        self.cutoff_grade.setValue(economic_rule.cutoff)

        # Update display
        self.update_economic_rule_display(economic_rule)

        # Log the sync
        logger.info(f"Synced economic rule to Waste/Ore tab: {economic_rule.format_for_display()}")

        QMessageBox.information(
            self,
            "Rule Synced",
            f"Economic rule synced successfully:\n\n{economic_rule.format_with_codes()}"
        )

    def _check_rule_mismatch(self, *args):
        """Detect and warn if Waste/Ore fields diverge from Economic tab rule."""
        if not self._parent_window:
            return

        # Get economic rule from Economic tab
        economic_rule = self._parent_window.tab_economic.get_economic_rule()
        if not economic_rule:
            return

        # Get current values from this tab
        current_field = self.indicator_field.currentText()
        current_op = self.cutoff_op.currentText()
        current_cutoff = self.cutoff_grade.value()

        # Detect mismatch
        mismatch_msg = EconomicRuleManager.detect_mismatch(
            economic_rule,
            current_field,
            current_op,
            current_cutoff
        )

        if mismatch_msg:
            # Show mismatch warning
            self.mismatch_banner.setText(f"⚠️ {mismatch_msg}")
            self.mismatch_banner.setVisible(True)
            logger.warning(f"Economic rule mismatch detected: {mismatch_msg}")
        else:
            # Hide mismatch banner (rules match)
            self.mismatch_banner.setVisible(False)

    def get_ui_engine(self):
        return self.ui_engine

    def get_state(self):
        if 'WasteOreUIState' not in globals() or not self.ui_engine:
            return None
        
        state = WasteOreUIState()
        
        state.indicator_field = self.indicator_field.currentText()
        state.cutoff_grade = self.cutoff_grade.value()
        state.cutoff_operator = self.cutoff_op.currentText()
        state.ore_code = int(self.ore_code.value())
        state.waste_code = int(self.waste_code.value())
        
        # Weighting
        weighting_map = {
            "Length": WeightingMode.LENGTH,
            "Mass": WeightingMode.MASS,
            "Density": WeightingMode.DENSITY,
        }
        state.weighting_mode = weighting_map.get(self.weighting.currentText(), WeightingMode.LENGTH)
        
        state.composite_length = self.comp_length.value()
        
        # Partial strategy
        partial_map = {
            "Discard": PartialStrategy.DISCARD,
            "Keep": PartialStrategy.KEEP,
            "Merge": PartialStrategy.MERGE,
            "Auto": PartialStrategy.AUTO,
        }
        state.partial_strategy = partial_map.get(self.partial_strategy.currentText(), PartialStrategy.AUTO)
        state.auto_partial_fraction = self.auto_fraction.value()
        
        state.exclude_qaqc = self.cb_exclude_qaqc.isChecked()
        state.treat_null_as_zero = self.cb_treat_null_as_zero.isChecked()
        
        return state


