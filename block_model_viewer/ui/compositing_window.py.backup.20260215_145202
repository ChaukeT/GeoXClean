        if not hasattr(self, '_last_composites_df') or self._last_composites_df is None:
            QMessageBox.warning(self, "No Composites", "Please run compositing first.")
            return
        
        try:
            df = self._last_composites_df
            composites = getattr(self, '_last_composites', None)
            
            # Save to registry
            self._save_composites_to_registry(df, composites)
            
            # Update status
            self.status_label.setText(f"✅ Applied {len(df)} composites to Registry. Variogram/Kriging panels will now use composited data.")
            self.status_label.setStyleSheet("color: #4CAF50; font-weight: bold;")
            
            # Show confirmation
