    def _restore_waste_ore_state(self, state: dict):
        """Restore WasteOreTab state."""
        try:
            tab = self.tab_waste_ore
            if not state:
                return

            if 'indicator_field' in state and hasattr(tab, 'indicator_field'):
                idx = tab.indicator_field.findText(state['indicator_field'])
                if idx >= 0:
                    tab.indicator_field.setCurrentIndex(idx)

            if 'cutoff_grade' in state and hasattr(tab, 'cutoff_grade'):
                tab.cutoff_grade.setValue(state['cutoff_grade'])

            if 'cutoff_operator' in state and hasattr(tab, 'cutoff_op'):
                idx = tab.cutoff_op.findText(state['cutoff_operator'])
                if idx >= 0:
                    tab.cutoff_op.setCurrentIndex(idx)

            if 'ore_code' in state and hasattr(tab, 'ore_code'):
                tab.ore_code.setValue(state['ore_code'])

            if 'waste_code' in state and hasattr(tab, 'waste_code'):
                tab.waste_code.setValue(state['waste_code'])

            if 'weighting' in state and hasattr(tab, 'weighting'):
                idx = tab.weighting.findText(state['weighting'])
                if idx >= 0:
                    tab.weighting.setCurrentIndex(idx)

            if 'composite_length' in state and hasattr(tab, 'comp_length'):
                tab.comp_length.setValue(state['composite_length'])

            if 'partial_strategy' in state and hasattr(tab, 'partial_strategy'):
                idx = tab.partial_strategy.findText(state['partial_strategy'])
                if idx >= 0:
                    tab.partial_strategy.setCurrentIndex(idx)

            if 'auto_fraction' in state and hasattr(tab, 'auto_fraction'):
                tab.auto_fraction.setValue(state['auto_fraction'])

            if 'exclude_qaqc' in state and hasattr(tab, 'cb_exclude_qaqc'):
                tab.cb_exclude_qaqc.setChecked(state['exclude_qaqc'])

            if 'treat_null_as_zero' in state and hasattr(tab, 'cb_treat_null_as_zero'):
                tab.cb_treat_null_as_zero.setChecked(state['treat_null_as_zero'])

        except Exception as e:
            logger.debug(f"Could not restore waste/ore state: {e}")

