                    is_valid, warnings = EconomicRuleManager.validate_rule(economic_rule)
                    if not is_valid:
                        warning_text = "\n".join(warnings)
                        logger.warning(f"Economic rule validation warnings:\n{warning_text}")

        except Exception as e:
            logger.debug(f"Error updating economic rule display on tab change: {e}")

