        self.partial_strategy.addItems(["Discard", "Keep", "Merge", "Auto"])
        l_handle.addRow("End of Hole:", self.partial_strategy)
        
        self.auto_fraction = self._make_spin(0.5, 0.0, 1.0)
        self.auto_fraction.setSingleStep(0.1)
        l_handle.addRow("Auto Merge Ratio:", self.auto_fraction)
        
        gb_handle.setLayout(l_handle)
        main_layout.addWidget(gb_handle)

        # 4. QA/QC
        gb_qaqc = QGroupBox("Filters")
        l_qaqc = QVBoxLayout()
        
        self.cb_exclude_qaqc = QCheckBox("Exclude Standards/Blanks/Duplicates")
        l_qaqc.addWidget(self.cb_exclude_qaqc)
        
        self.cb_treat_null_as_zero = QCheckBox("Treat Missing Grades as Zero")
        self.cb_treat_null_as_zero.setChecked(True)
        self.cb_treat_null_as_zero.setToolTip(
            "If checked, missing/NaN grades are treated as 0.0 (mining standard).\n"
            "If unchecked, missing grades are excluded from weighting (partial sampling)."
        )
        l_qaqc.addWidget(self.cb_treat_null_as_zero)
        
        h_rec = QHBoxLayout()
        h_rec.addWidget(QLabel("Min Recovery (%):"))
        self.min_recovery = self._make_spin(0.0, 0.0, 100.0)
        h_rec.addWidget(self.min_recovery)
        h_rec.addStretch()
        l_qaqc.addLayout(h_rec)
        
        gb_qaqc.setLayout(l_qaqc)
        main_layout.addWidget(gb_qaqc)

        main_layout.addStretch()

        # Logic
        self.ui_engine = NumericalUIEngine() if 'NumericalUIEngine' in globals() else None
        
        self.method_selector.currentIndexChanged.connect(self._update_params_ui)
        self.weighting.currentIndexChanged.connect(self._update_weighting_warning)
        self._update_params_ui()

    def _make_spin(self, val, min_v, max_v, tooltip=""):
        sb = QDoubleSpinBox()
        sb.setRange(min_v, max_v)
        sb.setValue(val)
        sb.setToolTip(tooltip)
        sb.setButtonSymbols(QDoubleSpinBox.ButtonSymbols.UpDownArrows)
        return sb

    def _update_weighting_warning(self):
        if self.weighting.currentText() in ("Mass", "Density"):
            self.weighting_warning.show()
        else:
            self.weighting_warning.hide()

    def _update_params_ui(self):
        # Clear layout rows
        while self.params_layout.rowCount() > 0:
            self.params_layout.removeRow(0)

        method = self.method_selector.currentText()

        if method in ["Fixed Length", "Equal Volume", "True Thickness"]:
            label = "Target Length (m):"
            if method == "True Thickness":
                label = "True Thickness (m):"
            self.params_layout.addRow(label, self.comp_length)
            
        elif method == "Equal Mass":
            self.params_layout.addRow("Target Mass (t):", self.target_mass)

        elif method == "Bench Aligned":
            self.params_layout.addRow("Bench Height (m):", self.bench_height)
            self.params_layout.addRow("RL Offset (m):", self.bench_offset)

        elif method == "Rolling Window":
            self.params_layout.addRow("Window Length (m):", self.window_length)
            self.params_layout.addRow("Step Size (m):", self.window_step)

    def get_ui_engine(self):
        return self.ui_engine

    def get_state(self):
        if 'NumericalUIState' not in globals() or not self.ui_engine:
            return None
        
        state = NumericalUIState()
        
        # Map method selector to NumericalMode
        method_map = {
            "Fixed Length": NumericalMode.FIXED_LENGTH,
            "Equal Mass": NumericalMode.EQUAL_MASS,
            "Equal Volume": NumericalMode.EQUAL_VOLUME,
            "True Thickness": NumericalMode.TRUE_THICKNESS,
            "Bench Aligned": NumericalMode.BENCH_ALIGNED,
            "Rolling Window": NumericalMode.ROLLING_WINDOW,
        }
        state.mode = method_map.get(self.method_selector.currentText(), NumericalMode.FIXED_LENGTH)
        
        # Map weighting
        weighting_map = {
            "Length": WeightingMode.LENGTH,
            "Mass": WeightingMode.MASS,
            "Density": WeightingMode.DENSITY,
        }
        state.weighting_mode = weighting_map.get(self.weighting.currentText(), WeightingMode.LENGTH)
        
        # Parameters
        state.composite_length = self.comp_length.value()
        state.target_mass = self.target_mass.value() if state.mode == NumericalMode.EQUAL_MASS else None
        state.bench_height = self.bench_height.value() if state.mode == NumericalMode.BENCH_ALIGNED else None
        state.bench_offset = self.bench_offset.value() if state.mode == NumericalMode.BENCH_ALIGNED else 0.0
        state.rolling_window_length = self.window_length.value() if state.mode == NumericalMode.ROLLING_WINDOW else None
        state.rolling_step = self.window_step.value() if state.mode == NumericalMode.ROLLING_WINDOW else None
        
        # Partial strategy
        partial_map = {
            "Discard": PartialStrategy.DISCARD,
            "Keep": PartialStrategy.KEEP,
            "Merge": PartialStrategy.MERGE,
            "Auto": PartialStrategy.AUTO,
        }
        state.partial_strategy = partial_map.get(self.partial_strategy.currentText(), PartialStrategy.AUTO)
        state.auto_partial_fraction = self.auto_fraction.value()
        
        # QA/QC
        state.exclude_qaqc = self.cb_exclude_qaqc.isChecked()
        state.treat_null_as_zero = self.cb_treat_null_as_zero.isChecked()
        recovery_val = self.min_recovery.value()
        state.min_recovery = recovery_val if recovery_val > 0 else None
        
        return state


