        """
        Handle tab changes to update Economic Rule display in Waste/Ore tab.

        When switching to Waste/Ore tab, automatically update the economic rule
        display to show the current rule from Economic tab and detect mismatches.
        """
        try:
            # Get the widget at the current tab index
