class BaseCompositingTab(QWidget):
    def get_state(self):
        raise NotImplementedError

    def get_ui_engine(self):
        raise NotImplementedError

    def apply_validation_result(self, result):
        """
        Show validation errors.
        """
        if result.ok:
            return True

        # Collect error messages
        errors = [f"• {m.field}: {m.message}" for m in result.errors]
        warnings = [f"• {m.field}: {m.message}" for m in result.warnings]

        text = ""
        if errors:
            text += "<b>Errors:</b><br>" + "<br>".join(errors) + "<br><br>"
        if warnings:
            text += "<b>Warnings:</b><br>" + "<br>".join(warnings)

        QMessageBox.warning(self, "Validation Failed", text)
        return False


