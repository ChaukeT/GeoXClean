        )
        self.setAttribute(Qt.WidgetAttribute.WA_DeleteOnClose, True)

        self.intervals = intervals
        self.compositing_engine = compositing_engine
        self.controller = controller
        
        # Store last composites for registry application
        self._last_composites_df = None
        self._last_composites = None
        self._last_config = None  # Store config for audit trail

