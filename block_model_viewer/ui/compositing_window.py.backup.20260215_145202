    def _update_rule_signature(self, *args):
        """Update the rule signature display (JORC/SAMREC audit trail)."""
        try:
            rule = EconomicRule(
                field=self.cutoff_field.currentText(),
                operator=self.op.currentText(),
                cutoff=self.val.value()
            )
            signature = rule.get_signature()
            display_text = f"Rule: {rule.format_for_display()} | Signature: {signature}"
            self.rule_signature_label.setText(display_text)
            self.rule_signature_label.setToolTip(
                f"JORC/SAMREC Audit Signature\n\n"
                f"This signature uniquely identifies the economic rule.\n"
                f"All composites generated with this rule will reference: {signature}\n\n"
                f"Rule: {rule.format_with_codes()}"
            )
        except Exception as e:
            self.rule_signature_label.setText(f"Invalid rule: {e}")
            logger.debug(f"Could not generate rule signature: {e}")

    def get_economic_rule(self) -> Optional[EconomicRule]:
        """
        Get the current economic rule definition.

        Returns:
            EconomicRule object or None if rule is invalid
        """
        try:
            return EconomicRule(
                field=self.cutoff_field.currentText(),
                operator=self.op.currentText(),
                cutoff=self.val.value(),
                name=f"{self.cutoff_field.currentText()} Economic Rule"
            )
        except Exception as e:
            logger.error(f"Failed to create economic rule: {e}")
            return None

    def _on_dilution_rule_changed(self, rule_text: str):
        """Enable/disable min_waste_composite_length based on dilution rule."""
        is_advanced = rule_text in ("Advanced", "Advanced+")
        self.min_waste_composite_length.setEnabled(is_advanced)
    
    def _on_true_thickness_toggled(self, checked: bool):
        """Enable/disable true thickness parameters."""
        self.true_thickness_dip.setEnabled(checked)
        self.true_thickness_dip_azimuth.setEnabled(checked)

    def get_ui_engine(self):
        return self.ui_engine

    def get_state(self):
        if 'EconomicUIState' not in globals() or not self.ui_engine:
            return None
        
        state = EconomicUIState()
        
        state.cutoff_field = self.cutoff_field.currentText()
        state.cutoff_grade = self.val.value()
        state.cutoff_operator = self.op.currentText()
        
        # Weighting
        weighting_map = {
            "Length": WeightingMode.LENGTH,
            "Mass": WeightingMode.MASS,
            "Density": WeightingMode.DENSITY,
        }
        state.weighting_mode = weighting_map.get(self.weighting.currentText(), WeightingMode.LENGTH)
        
        # Economic compositing parameters
        dilution_rule_text = self.dilution_rule.currentText().lower().replace("+", "_plus")
        state.dilution_rule = dilution_rule_text
        
        min_ore_comp_val = self.min_ore_composite_length.value()
        state.min_ore_composite_length = min_ore_comp_val if min_ore_comp_val > 0 else None
        
        max_inc_waste_val = self.max_included_waste.value()
        state.max_included_waste = max_inc_waste_val if max_inc_waste_val > 0 else None
        
        max_cons_waste_val = self.max_consecutive_waste.value()
        state.max_consecutive_waste = max_cons_waste_val if max_cons_waste_val > 0 else None
        
        state.keep_short_high_grade = self.keep_short_high_grade.isChecked()
        min_linear_val = self.min_linear_grade.value()
        state.min_linear_grade = min_linear_val if min_linear_val > 0 else None
        
        min_waste_comp_val = self.min_waste_composite_length.value()
        state.min_waste_composite_length = min_waste_comp_val if min_waste_comp_val > 0 else None
        
        # Advanced options
        state.composite_twice = self.composite_twice.isChecked()
        state.use_true_thickness = self.use_true_thickness.isChecked()
        
        true_thick_dip_val = self.true_thickness_dip.value()
        state.true_thickness_dip = true_thick_dip_val if abs(true_thick_dip_val) > 1e-8 else None
        
        true_thick_az_val = self.true_thickness_dip_azimuth.value()
        state.true_thickness_dip_azimuth = true_thick_az_val if abs(true_thick_az_val) > 1e-8 else None
        
        state.exclude_qaqc = self.cb_exclude_qaqc.isChecked()
        state.treat_null_as_zero = self.cb_treat_null_as_zero.isChecked()
        
        return state


