                "}"
            )
            self._check_rule_mismatch()
        else:
            self.rule_display_label.setText("⚠️ No economic rule defined in Economic tab")
            self.rule_display_label.setStyleSheet(
                "QLabel { "
                f"background-color: {ModernColors.CARD_BG}; "
