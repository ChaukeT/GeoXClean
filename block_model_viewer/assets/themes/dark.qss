/* Dark Theme Stylesheet for BlockModelViewer */

/* Main Window */
QMainWindow {
    background-color: #1e1e1e;
    color: #e0e0e0;
}

/* Menu Bar */
QMenuBar {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border-bottom: 1px solid #3d3d3d;
    padding: 4px;
}

QMenuBar::item {
    background-color: transparent;
    padding: 6px 12px;
    border-radius: 4px;
}

QMenuBar::item:selected {
    background-color: #3d3d3d;
    color: #64b5f6;
}

QMenuBar::item:pressed {
    background-color: #4d4d4d;
}

/* Menus */
QMenu {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    padding: 4px;
}

QMenu::item {
    padding: 6px 24px;
    border-radius: 4px;
}

QMenu::item:selected {
    background-color: #3d3d3d;
    color: #64b5f6;
}

QMenu::separator {
    height: 1px;
    background-color: #3d3d3d;
    margin: 4px 8px;
}

/* Toolbar */
QToolBar {
    background-color: #2d2d2d;
    border: none;
    border-bottom: 1px solid #3d3d3d;
    spacing: 4px;
    padding: 4px;
}

QToolBar::separator {
    background-color: #3d3d3d;
    width: 1px;
    margin: 4px 2px;
}

/* Buttons */
QPushButton {
    background-color: #3d3d3d;
    color: #e0e0e0;
    border: 1px solid #4d4d4d;
    border-radius: 4px;
    padding: 6px 12px;
    min-height: 24px;
}

QPushButton:hover {
    background-color: #4d4d4d;
    border-color: #5d5d5d;
}

QPushButton:pressed {
    background-color: #2d2d2d;
}

QPushButton:disabled {
    background-color: #2d2d2d;
    color: #5d5d5d;
    border-color: #3d3d3d;
}

/* Tool Buttons */
QToolButton {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 4px;
}

QToolButton:hover {
    background-color: #3d3d3d;
    border-color: #4d4d4d;
}

QToolButton:pressed {
    background-color: #2d2d2d;
}

/* Dock Widgets */
QDockWidget {
    titlebar-close-icon: url(close.png);
    titlebar-normal-icon: url(float.png);
    color: #e0e0e0;
}

QDockWidget::title {
    background-color: #2d2d2d;
    color: #e0e0e0;
    padding: 6px;
    border-bottom: 1px solid #3d3d3d;
}

/* Tabs */
QTabWidget::pane {
    border: 1px solid #3d3d3d;
    background-color: #2d2d2d;
    top: -1px;
}

QTabBar::tab {
    background-color: #252525;
    color: #9e9e9e;
    border: 1px solid #3d3d3d;
    border-bottom: none;
    padding: 8px 16px;
    margin-right: 2px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

QTabBar::tab:selected {
    background-color: #2d2d2d;
    color: #64b5f6;
    border-color: #3d3d3d;
    border-bottom-color: #2d2d2d;
}

QTabBar::tab:hover:!selected {
    background-color: #353535;
    color: #bdbdbd;
}

/* Status Bar */
QStatusBar {
    background-color: #2d2d2d;
    color: #9e9e9e;
    border-top: 1px solid #3d3d3d;
}

/* Labels */
QLabel {
    color: #e0e0e0;
}

/* Line Edits */
QLineEdit {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 4px;
    padding: 4px 8px;
    selection-background-color: #1976d2;
    selection-color: #ffffff;
}

QLineEdit:focus {
    border-color: #64b5f6;
}

QLineEdit:disabled {
    background-color: #1e1e1e;
    color: #5d5d5d;
}

/* Spin Boxes */
QSpinBox, QDoubleSpinBox {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 4px;
    padding: 4px;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border-color: #64b5f6;
}

/* Combo Boxes */
QComboBox {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 4px;
    padding: 4px 8px;
}

QComboBox:hover {
    border-color: #4d4d4d;
}

QComboBox:focus {
    border-color: #64b5f6;
}

QComboBox::drop-down {
    border: none;
    width: 20px;
}

QComboBox::down-arrow {
    image: url(down_arrow.png);
    width: 12px;
    height: 12px;
}

QComboBox QAbstractItemView {
    background-color: #2d2d2d;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    selection-background-color: #1976d2;
    selection-color: #ffffff;
}

/* Check Boxes */
QCheckBox {
    color: #e0e0e0;
    spacing: 6px;
}

QCheckBox::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #5d5d5d;
    border-radius: 3px;
    background-color: #252525;
}

QCheckBox::indicator:hover {
    border-color: #7d7d7d;
}

QCheckBox::indicator:checked {
    background-color: #1976d2;
    border-color: #1976d2;
}

QCheckBox::indicator:disabled {
    background-color: #1e1e1e;
    border-color: #3d3d3d;
}

/* Radio Buttons */
QRadioButton {
    color: #e0e0e0;
    spacing: 6px;
}

QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 2px solid #5d5d5d;
    border-radius: 9px;
    background-color: #252525;
}

QRadioButton::indicator:hover {
    border-color: #7d7d7d;
}

QRadioButton::indicator:checked {
    background-color: #1976d2;
    border-color: #1976d2;
}

/* Scroll Bars */
QScrollBar:vertical {
    background-color: #252525;
    width: 12px;
    border: none;
}

QScrollBar::handle:vertical {
    background-color: #5d5d5d;
    border-radius: 6px;
    min-height: 20px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background-color: #7d7d7d;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0px;
}

QScrollBar:horizontal {
    background-color: #252525;
    height: 12px;
    border: none;
}

QScrollBar::handle:horizontal {
    background-color: #5d5d5d;
    border-radius: 6px;
    min-width: 20px;
    margin: 2px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #7d7d7d;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0px;
}

/* Group Boxes */
QGroupBox {
    border: 1px solid #3d3d3d;
    border-radius: 4px;
    margin-top: 12px;
    padding-top: 12px;
    color: #e0e0e0;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 0 4px;
    color: #9e9e9e;
}

/* Progress Bars */
QProgressBar {
    background-color: #3d3d3d;
    border: none;
    border-radius: 4px;
    text-align: center;
    color: #e0e0e0;
}

QProgressBar::chunk {
    background-color: #1976d2;
    border-radius: 4px;
}

/* Sliders */
QSlider::groove:horizontal {
    background-color: #3d3d3d;
    height: 4px;
    border-radius: 2px;
}

QSlider::handle:horizontal {
    background-color: #1976d2;
    width: 16px;
    height: 16px;
    margin: -6px 0;
    border-radius: 8px;
}

QSlider::handle:horizontal:hover {
    background-color: #64b5f6;
}

/* List Widgets */
QListWidget {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 4px;
}

QListWidget::item {
    padding: 4px;
}

QListWidget::item:selected {
    background-color: #1976d2;
    color: #ffffff;
}

QListWidget::item:hover {
    background-color: #353535;
}

/* Tree Widgets */
QTreeWidget {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 4px;
}

QTreeWidget::item {
    padding: 4px;
}

QTreeWidget::item:selected {
    background-color: #1976d2;
    color: #ffffff;
}

QTreeWidget::item:hover {
    background-color: #353535;
}

/* Table Widgets */
QTableWidget {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 4px;
    gridline-color: #3d3d3d;
}

QTableWidget::item {
    padding: 4px;
}

QTableWidget::item:selected {
    background-color: #1976d2;
    color: #ffffff;
}

QHeaderView::section {
    background-color: #2d2d2d;
    color: #e0e0e0;
    padding: 6px;
    border: 1px solid #3d3d3d;
}

/* Column Mapping Dialog - Custom Widgets */
/* Mapping Field Row - generic for any widget with mappingRow property */
*[mappingRow="true"] {
    background-color: #252525;
    border: 1px solid #3d3d3d;
    border-radius: 6px;
}

*[mappingRow="true"]:hover {
    background-color: #2d2d2d;
    border-color: #4d4d4d;
}

/* Badges */
QLabel[badge="required"] {
    background-color: #3d1e1e;
    color: #ef4444;
    border-radius: 3px;
}

QLabel[badge="optional"] {
    background-color: #353535;
    color: #9e9e9e;
    border-radius: 3px;
}

/* Hints and Subtitles */
QLabel[hint="true"], QLabel[subtitle="true"] {
    color: #9e9e9e;
}

QLabel[statLabel="true"] {
    color: #757575;
}

QLabel[nullLabel="true"], QLabel[nullValue="true"] {
    color: #f59e0b;
}

/* Status Icons */
QLabel[statusIcon="unmapped"] {
    color: #757575;
}

QLabel[statusIcon="required-unmapped"] {
    color: #ef4444;
}

QLabel[statusIcon="optional-unmapped"] {
    color: #757575;
}

QLabel[statusIcon="mapped"] {
    color: #10b981;
}

/* Status Messages */
QLabel[statusMessage="true"] {
    color: #9e9e9e;
}

QLabel[statusMessage="success"] {
    color: #10b981;
    font-style: normal;
}

QLabel[statusMessage="error"] {
    color: #ef4444;
}

/* Selection Badge */
QLabel[selectionBadge="all"] {
    background-color: #1e3a2e;
    color: #10b981;
    border-radius: 12px;
}

QLabel[selectionBadge="partial"] {
    background-color: #1e2a3d;
    color: #64b5f6;
    border-radius: 12px;
}

QLabel[selectionBadge="none"] {
    background-color: #3d1e1e;
    color: #ef4444;
    border-radius: 12px;
}

/* Grade/Property Column Cards - generic for any widget with gradeCard property */
*[gradeCard="true"] {
    background-color: #252525;
    border: 2px solid #3d3d3d;
    border-radius: 6px;
}

*[gradeCard="true"]:hover {
    background-color: #2d2d2d;
    border-color: #4d4d4d;
}

*[gradeCard="true"][selected="true"] {
    background-color: #1e2a3d;
    border-color: #64b5f6;
}

*[gradeCard="true"][selected="true"]:hover {
    background-color: #253548;
}

*[gradeCard="true"][selected="false"] {
    background-color: #252525;
    border-color: #3d3d3d;
}

/* Selection Indicator */
QFrame[selectionIndicator="true"] {
    background-color: #64b5f6;
    border-radius: 8px;
}

*[selected="false"] QFrame[selectionIndicator="true"] {
    background-color: #5d5d5d;
}

/* Dialog Header */
QFrame[dialogHeader="true"] {
    background-color: #252525;
    border: 1px solid #3d3d3d;
    border-radius: 8px;
}

/* Warning Frame */
QFrame[warning="true"] {
    background-color: #3d2e1e;
    border: 1px solid #f59e0b;
    border-radius: 6px;
}

/* Message Boxes & Dialogs */
QMessageBox {
    background-color: #2d2d2d;
    color: #e0e0e0;
}

QMessageBox QLabel {
    color: #e0e0e0;
    background-color: transparent;
}

QMessageBox QPushButton {
    background-color: #3d3d3d;
    color: #e0e0e0;
    border: 1px solid #4d4d4d;
    border-radius: 4px;
    padding: 6px 16px;
    min-width: 60px;
}

QMessageBox QPushButton:hover {
    background-color: #4d4d4d;
    border-color: #5d5d5d;
}

QMessageBox QPushButton:pressed {
    background-color: #2d2d2d;
}

QDialog {
    background-color: #2d2d2d;
    color: #e0e0e0;
}

QDialog QLabel {
    color: #e0e0e0;
}

QDialog QTextEdit {
    background-color: #252525;
    color: #e0e0e0;
    border: 1px solid #3d3d3d;
    border-radius: 4px;
}

