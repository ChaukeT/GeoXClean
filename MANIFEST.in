# Step 13: MANIFEST.in for packaging
# Include all necessary files for distribution

# Include README and LICENSE
include README.md
include LICENSE
include requirements.txt
include requirements-dev.txt

# Include UI files
recursive-include block_model_viewer/ui *.ui
recursive-include block_model_viewer/ui *.qss
recursive-include block_model_viewer/ui *.svg
recursive-include block_model_viewer/ui *.png
recursive-include block_model_viewer/ui *.jpg

# Include icons directory
recursive-include block_model_viewer/ui/icons *

# Include assets (branding, icons, themes)
recursive-include block_model_viewer/assets *

# Include sample data if present
recursive-include block_model_viewer/sample_data *

# Include config templates
recursive-include block_model_viewer/config *.yaml
recursive-include block_model_viewer/config *.yml
recursive-include block_model_viewer/config *.json

# Include documentation
recursive-include docs *.md
recursive-include docs *.rst

# Exclude test files from distribution
global-exclude *.pyc
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .git*
global-exclude .DS_Store
global-exclude tests/*
global-exclude *.test.py
global-exclude *_test.py

