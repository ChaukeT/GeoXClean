<?xml version="1.0" encoding="UTF-8"?>
<!--
  GeoX MSI Installer - WiX Toolset v4
  
  This installer supports automatic upgrades via the MajorUpgrade element.
  When a user installs a newer version, the old version is automatically removed.
  
  Build with: wix build GeoX.wxs -ext WixToolset.UI.wixext -o GeoX_Setup.msi
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <!-- 
    IMPORTANT: Never change the UpgradeCode GUID - it identifies the product family.
    Changing it will break upgrade detection and leave orphaned installations.
  -->
  <!-- Version is passed from build script: wix build -d Version=1.0.0 -->
  <?define Version = "1.0.0" ?>
  
  <Package Name="GeoX"
           Version="$(var.Version)"
           Manufacturer="GeoX Development Team"
           UpgradeCode="A1B2C3D4-E5F6-4A5B-9C8D-7E6F5A4B3C2D"
           Language="1033"
           Codepage="1252"
           InstallerVersion="500"
           Compressed="yes"
           Scope="perUser">

    <!-- 
      MajorUpgrade handles automatic uninstall of previous versions.
      - AllowSameVersionUpgrades: allows reinstalling the same version
      - DowngradeErrorMessage: prevents installing older versions over newer
    -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of GeoX is already installed. Please uninstall it first."
                  AllowSameVersionUpgrades="yes"
                  Schedule="afterInstallInitialize"/>

    <!-- Embed all files into the MSI (single file distribution) -->
    <!-- Use LZMA compression for large installers (>2GB) -->
    <!-- Note: WiX v4 uses CompressionLevel="high" for LZMA, "medium" for MSZIP -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high"/>

    <!-- Product icon shown in Add/Remove Programs -->
    <Icon Id="GeoXIcon" SourceFile="..\..\block_model_viewer\assets\branding\icon.ico"/>
    <Property Id="ARPPRODUCTICON" Value="GeoXIcon"/>
    <Property Id="ARPHELPLINK" Value="https://github.com/your-org/geox"/>
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/your-org/geox"/>

    <!-- Use WiX standard UI for install wizard -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER"/>
    
    <!-- License agreement (optional - create a license.rtf file) -->
    <!-- <WixVariable Id="WixUILicenseRtf" Value="license.rtf"/> -->

    <!-- Custom banner and dialog images (optional) -->
    <!-- <WixVariable Id="WixUIBannerBmp" Value="banner.bmp"/> -->
    <!-- <WixVariable Id="WixUIDialogBmp" Value="dialog.bmp"/> -->

    <!-- Feature definition - single feature containing all components -->
    <Feature Id="ProductFeature" Title="GeoX" Level="1">
      <ComponentGroupRef Id="ProductComponents"/>
      <ComponentGroupRef Id="InternalComponents"/>
      <ComponentRef Id="StartMenuShortcut"/>
      <ComponentRef Id="DesktopShortcut"/>
    </Feature>

    <!-- Standard install directory structure -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="INSTALLFOLDER" Name="GeoX">
        <Directory Id="InternalFolder" Name="_internal"/>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu directory -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="GeoX"/>
    </StandardDirectory>

    <!-- Desktop directory for shortcut -->
    <StandardDirectory Id="DesktopFolder"/>

    <!-- Main executable and root files -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable" Guid="B2C3D4E5-F6A7-4B5C-8D9E-0F1A2B3C4D5E">
        <File Id="GeoXExe" 
              Source="..\..\dist\GeoX\GeoX.exe" 
              KeyPath="yes">
          <!-- File association example (optional) -->
          <!-- <Shortcut Id="FileAssocShortcut" Advertise="yes"/> -->
        </File>
      </Component>
    </ComponentGroup>

    <!-- 
      Internal folder components (_internal directory from PyInstaller)
      This uses a ComponentGroup that will be populated by the build script
      using the 'wix heat' command to harvest all files automatically.
    -->
    <ComponentGroup Id="InternalComponents" Directory="InternalFolder">
      <!-- 
        Files will be added here by running:
        wix heat dir "..\..\dist\GeoX\_internal" -cg InternalComponents -dr InternalFolder -var var.InternalDir -ag -sfrag -srd -o InternalFiles.wxs
        
        For manual builds or if heat doesn't work, you can use:
        <Component Id="InternalPlaceholder" Guid="*">
          <CreateFolder/>
        </Component>
        
        And manually specify critical DLLs/files.
      -->
    </ComponentGroup>

    <!-- Start Menu shortcut -->
    <Component Id="StartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="C3D4E5F6-A7B8-4C5D-9E0F-1A2B3C4D5E6F">
      <Shortcut Id="StartMenuShortcut"
                Name="GeoX"
                Description="3D Block Model Visualization and Analysis"
                Target="[INSTALLFOLDER]GeoX.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="GeoXIcon"/>
      <RemoveFolder Id="CleanupStartMenu" Directory="ApplicationProgramsFolder" On="uninstall"/>
      <RegistryValue Root="HKCU" Key="Software\GeoX" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes"/>
    </Component>

    <!-- Desktop shortcut -->
    <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="D4E5F6A7-B8C9-4D5E-0F1A-2B3C4D5E6F7A">
      <Shortcut Id="DesktopShortcut"
                Name="GeoX"
                Description="3D Block Model Visualization and Analysis"
                Target="[INSTALLFOLDER]GeoX.exe"
                WorkingDirectory="INSTALLFOLDER"
                Icon="GeoXIcon"/>
      <RegistryValue Root="HKCU" Key="Software\GeoX" Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes"/>
    </Component>

  </Package>
</Wix>

